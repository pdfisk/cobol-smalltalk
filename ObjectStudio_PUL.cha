ONFIGURATION SECTION. INPUT-OUTPUT SECTION. DATA DIVISION. FILE SECTION. WORKING-STORAGE SECTION. LINKAGE SECTION. PROCEDURE DIVISION. DISPLAY "Hello World". STOP RUN.'</body></methods><remove-selector><class-id>CobolWorkbench class</class-id> <selector>addAmt</selector></remove-selector><methods><class-id>CobolScanner class</class-id> <category>testing</category><body package="CobolStudio" selector="test1">test1| src |src := CobolWorkbench hello.^ src</body></methods><methods><class-id>CobolScanner class</class-id> <category>testing</category><body package="CobolStudio" selector="test1">test1| src |src := CobolWorkbench hello.^ CobolScanner on: src</body></methods><methods><class-id>CobolScanner class</class-id> <category>testing</category><body package="CobolStudio" selector="test1">test1| scanner src |src := CobolWorkbench hello.scanner := CobolScanner on: src.scanner allTokens.</body></methods><methods><class-id>CobolScanner class</class-id> <category>testing</category><body package="CobolStudio" selector="test1">test1	| scanner src |	src := CobolWorkbench hello.	scanner := CobolScanner on: src.	scanner allTokens</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '2:15:09 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 2:15:09 AM on April 7, 2026."</do-it><component-created><name>Proxy-Database</name> <type>package</type></component-created><parcel-loaded><name>Proxy-Database</name> <filename>(OS.PortableFilename fromComponents: #('$(OBJECTSTUDIO)' 'parcels' 'Proxy-Database.pcl'))</filename></parcel-loaded><component-created><name>Proxy-Database Controllers</name> <type>package</type></component-created><parcel-loaded><name>Proxy-Database Controllers</name> <filename>(OS.LogicalFilename fromComponents: #('C:\' 'Program Files (x86)' 'Cincom' 'ObjectStudio