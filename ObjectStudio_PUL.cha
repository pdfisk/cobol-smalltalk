: 			[self step.			^self locate: CobolToken plus].	self isEqual		ifTrue: 			[self step.			^self locate: CobolToken equal].	"Colon or :: (reference modification separator)."	self isColon		ifTrue: 			[self step.			self isColon				ifTrue: 					[self step.					^self locate: CobolToken doubleColon].			^self locate: CobolToken colon].	"Minus: operator (not part of an identifier here — identifiers start alpha)."	self isMinus		ifTrue: 			[self step.			^self locate: CobolToken minus].	"Asterisk or ** (exponentiation)."	self isAsterisk		ifTrue: 			[self step.			self isPeekAsterisk				ifTrue: 					[self step.					^self locate: CobolToken exponent].			^self locate: CobolToken asterisk].	"Slash."	self isSlash		ifTrue: 			[self step.			^self locate: CobolToken slash].	"Relational operators: &gt; &gt;= &lt; &lt;= &lt;&gt;."	self isGreater		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken greaterEqual].			^self locate: CobolToken greater].	self isLess		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken lessEqual].			self isPeekGreater				ifTrue: 					[self step.					^self locate: CobolToken notEqual].			^self locate: CobolToken less].	"Numeric literal (leading digit)."	self isDigit ifTrue: [^self scanForNumber].	"String literals."	self isDoubleQuote ifTrue: [^self scanForString].	self isSingleQuote ifTrue: [^self scanForSingleQuotedString].	"Identifier or keyword (must start with a letter)."	currentCharacter isLetter ifTrue: [^self scanForIdentifier].	"Picture starting with $"	self isDollar ifTrue: [^self scanForPic].	^self locate: (CobolToken error: istream)</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="nextToken">nextToken	"Return the next token from the input stream."	self row &gt;= 97 ifTrue: [('STEPPING: ' , self row asString) out].	self isEof ifTrue: [^self locate: CobolToken eof].	self skipWhitespace.	self isEof ifTrue: [^self locate: CobolToken eof].	"Inline comment *&gt; — skip to end of line."	self isInlineCommentStart		ifTrue: 			[self skipToEndOfLine.			^self nextToken].	"Single-character punctuation."	self isPeriod		ifTrue: 			[self step.			^self locate: CobolToken period].	self isComma		ifTrue: 			[self step.			^self locate: CobolToken comma].	self isSemicolon		ifTrue: 			[self step.			^self locate: CobolToken semicolon].	self isLeftParen		ifTrue: 			[self step.			^self locate: CobolToken leftParen].	self isRightParen		ifTrue: 			[self step.			^self locate: CobolToken rightParen].	self isPlus		ifTrue: 			[self step.			^self locate: CobolToken plus].	self isEqual		ifTrue: 			[self step.			^self locate: CobolToken equal].	"Colon or :: (reference modification separator)."	self isColon		ifTrue: 			[self step.			self isColon				ifTrue: 					[self step.					^self locate: CobolToken doubleColon].			^self locate: CobolToken colon].	"Minus: operator (not part of an identifier here — identifiers start alpha)."	self isMinus		ifTrue: 			[self step.			^self locate: CobolToken minus].	"Asterisk or ** (exponentiation)."	self isAsterisk		ifTrue: 			[self step.			self isPeekAsterisk				ifTrue: 					[self step.					^self locate: CobolToken exponent].			^self locate: CobolToken asterisk].	"Slash."	self isSlash		ifTrue: 			[self step.			^self locate: CobolToken slash].	"Relational operators: &gt; &gt;= &lt; &lt;= &lt;&gt;."	self isGreater		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken greaterEqual].			^self locate: CobolToken greater].	self isLess		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken lessEqual].			self isPeekGreater				ifTrue: 					[self step.					^self locate: CobolToken notEqual].			^self locate: CobolToken less].	"Numeric literal (leading digit)."	self isDigit ifTrue: [^self scanForNumber].	"String literals."	self isDoubleQuote ifTrue: [^self scanForString].	self isSingleQuote ifTrue: [^self scanForSingleQuotedString].	"Identifier or keyword (must start with a letter)."	currentCharacter isLetter ifTrue: [^self scanForIdentifier].	"Picture starting with $"	self isDollar ifTrue: [^self scanForPic].	^self locate: (CobolToken error: istream)</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '2:31:06 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 2:31:06 AM on April 8, 2026."</do-it><do-it>CobolWorkbench tokens:'cbl0001' </do-it><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="nextToken">nextToken	"Return the next token from the input stream."	self isEof ifTrue: [^self locate: CobolToken eof].	self skipWhitespace.	self isEof ifTrue: [^self locate: CobolToken eof].	"Inline comment *&gt; — skip to end of line."	self isInlineCommentStart		ifTrue: 			[self skipToEndOfLine.			^self nextToken].	"Single-character punctuation."	self isPeriod		ifTrue: 			[self step.			^self locate: CobolToken period].	self isComma		ifTrue: 			[self step.			^self locate: CobolToken comma].	self isSemicolon		ifTrue: 			[self step.			^self locate: CobolToken semicolon].	self isLeftParen		ifTrue: 			[self step.			^self locate: CobolToken leftParen].	self isRightParen		ifTrue: 			[self step.			^self locate: CobolToken rightParen].	self isPlus		ifTrue: 			[self step.			^self locate: CobolToken plus].	self isEqual		ifTrue: 			[self step.			^self locate: CobolToken equal].	"Colon or :: (reference modification separator)."	self isColon		ifTrue: 			[self step.			self isColon				ifTrue: 					[self step.					^self locate: CobolToken doubleColon].			^self locate: CobolToken colon].	"Minus: operator (not part of an identifier here — identifiers start alpha)."	self isMinus		ifTrue: 			[self step.			^self locate: CobolToken minus].	"Asterisk or ** (exponentiation)."	self isAsterisk		ifTrue: 			[self step.			self isPeekAsterisk				ifTrue: 					[self step.					^self locate: CobolToken exponent].			^self locate: CobolToken asterisk].	"Slash."	self isSlash		ifTrue: 			[self step.			^self locate: CobolToken slash].	"Relational operators: &gt; &gt;= &lt; &lt;= &lt;&gt;."	self isGreater		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken greaterEqual].			^self locate: CobolToken greater].	self isLess		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken lessEqual].			self isPeekGreater				ifTrue: 					[self step.					^self locate: CobolToken notEqual].			^self locate: CobolToken less].	"Numeric literal (leading digit)."	self isDigit ifTrue: [^self scanForNumber].	"String literals."	self isDoubleQuote ifTrue: [^self scanForString].	self isSingleQuote ifTrue: [^self scanForSingleQuotedString].	"Identifier or keyword (must start with a letter)."	currentCharacter isLetter ifTrue: [^self scanForIdentifier].	"Picture starting with $"	self isDollar ifTrue: [^self scanForPic].	^self locate: (CobolToken error: istream)</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '2:33:35 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 2:33:35 AM on April 8, 2026."</do-it><do-it>CobolWorkbench tokens:'cbl0001'</do-it><methods><class-id>CobolWorkbench class</class-id> <category>examples</category><body package="CobolStudio" selector="allTokens">allTokens	"CobolWorkbench allTokens"	| collection files scanner |	collection := OrderedCollection new.	files := CobolFile listFiles.	files do: 			[:file |			scanner := CobolScanner on: (CobolFile readFile: file).			collection add: scanner allTokens].	^collection</body></methods><do-it>CobolWorkbench allTokens</do-it><do-it>CobolWorkbench allTokens</do-it><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '2:35:40 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 2:35:40 AM on April 8, 2026."</do-it><comment><class-id>CobolParser</class-id><body>Recursive-descent parser for COBOL source code.Consumes a token stream from CobolScanner and produces AST nodes.Currently implements the full Identification Division:  IDENTIFICATION DIVISION.             (or ID DIVISION.)  PROGRAM-ID. program-name             [IS [INITIAL | RECURSIVE | COMMON] PROGRAM].  [AUTHOR.         comment-entry]  [INSTALLATION.   comment-entry]  [DATE-WRITTEN.   comment-entry]  [DATE-COMPILED.  comment-entry]  [SECURITY.       comment-entry]Usage:  node := CobolParser onString: myCobolSource.  node parseIdentificationDivision.</body></comment><class><name>CobolParser</name><environment>Smalltalk</environment><super>Core.Object</super><private>false</private><indexed-type>none</indexed-type><inst-vars>currentToken scanner </inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="currentToken">currentToken	^currentToken</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="currentToken:">currentToken: anObject	currentToken := anObject</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="scanner">scanner	^scanner</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="scanner:">scanner: anObject	scanner := anObject</body></methods><comment><class-id>CobolParser</class-id><body>Recursive-descent parser for COBOL source code.Consumes a token stream from CobolScanner and produces AST nodes.Currently implements the full Identification Division:  IDENTIFICATION DIVISION.             (or ID DIVISION.)  PROGRAM-ID. program-name             [IS [INITIAL | RECURSIVE | COMMON] PROGRAM].  [AUTHOR.         comment-entry]  [INSTALLATION.   comment-entry]  [DATE-WRITTEN.   comment-entry]  [DATE-COMPILED.  comment-entry]  [SECURITY.       comment-entry]Usage:  node := CobolParser onString: myCobolSource.  node parseIdentificationDivision.Instance Variables:	scanner		&lt;Object&gt;	a CobolScanner	currentToken	&lt;Object&gt;	a CobolToken</body></comment><do-it>CobolParser organization addCategory: #creation</do-it><methods><class-id>CobolParser</class-id> <category>creation</category><body package="CobolStudio" selector="on:">on: aString	self scanner: (CobolScanner on: aString).	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="advance">advance	"Consume the current token and move to the next one."	currentToken := scanner nextToken</body></methods><do-it>CobolParser organization addCategory: #matching</do-it><methods><class-id>CobolParser</class-id> <category>matching</category><body package="CobolStudio" selector="matchKeyword:">matchKeyword: aKeywordSymbol	| token |	token := self currentToken.	token ifNil: [ ^ false ].	token isIdentifier ifFalse: [ ^ false ].	token value asString asLowercase asSymbol = aKeywordSymbol		ifTrue: [			self advance.			^ true ]		ifFalse: [ ^ false ]</body></methods><methods><class-id>CobolParser</class-id> <category>matching</category><body package="CobolStudio" selector="matchKeyword:">matchKeyword: aKeywordSymbol	| token |	token := self currentToken.	token ifNil: [^false].	token isIdentifier ifFalse: [^false].	token value asString asLowercase asSymbol = aKeywordSymbol		ifTrue: 			[self advance.			^true]		ifFalse: [^false]</body></methods><methods><class-id>CobolParser</class-id> <category>matching</category><body package="CobolStudio" selector="matchPeriod">matchPeriod	| token |	token := self currentToken.	token ifNil: [ ^ false ].	token isPeriod		ifTrue: [			self advance.			^ true ]		ifFalse: [ ^ false ]</body></methods><methods><class-id>CobolParser</class-id> <category>matching</category><body package="CobolStudio" selector="matchPeriod">matchPeriod	| token |	token := self currentToken.	token ifNil: [^false].	token isPeriod		ifTrue: 			[self advance.			^true]		ifFalse: [^false]</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="listTokens">listTokens	self keywords do: [ :token | self log: token ]</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="listTokens">listTokens	self keywords do: [:token | self log: token]</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="log:">log: anObjectanObject out</body></methods><methods><class-id>CobolParser</class-id> <category>accessing</category><body package="CobolStudio" selector="log:">log: anObject	anObject out</body></methods><do-it>CobolParser organization addCategory: #parsing</do-it><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseProgram">parseProgram	self parseDivisions</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDivisions">parseDivisions	self		parseIdentificationDivision;		parseEnvironmentDivision;		parseDataDivision;		parseProcedureDivision</body></methods><class><name>CobolAst</name><environment>Smalltalk</environment><super>Core.Object</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolIdentificationDivision</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolIdentificationDivision</class-id> <category>initialize-release</category><body package="CobolStudio" selector="initialize">initialize	"Initialize a newly created instance. This method must answer the receiver."	super initialize.	" *** Replace this comment with the appropriate initialization code *** "	^self</body></methods><methods><class-id>CobolIdentificationDivision class</class-id> <category>instance creation</category><body package="CobolStudio" selector="new">new	"Answer a newly created and initialized instance."	^super new initialize</body></methods><class><name>CobolEnvironmentDivision</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolDataDivision</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolProcedureDivision</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseIdentificationDivision">parseIdentificationDivision	"Parse the Identification Division and return a CobolIdentificationDivision node.	 Grammar (simplified):	   id-div ::= ( IDENTIFICATION | ID ) DIVISION .	              program-id-paragraph	              [ author-paragraph ]	              [ installation-paragraph ]	              [ date-written-paragraph ]	              [ date-compiled-paragraph ]	              [ security-paragraph ]	"	| node |	node := CobolIdentificationDivision new.	"Accept either IDENTIFICATION or the abbreviation ID."	((self currentIsKeyword: 'IDENTIFICATION')		or: [self currentIsKeyword: 'ID'])			ifFalse: 				[self					error: 'Expected IDENTIFICATION or ID at start of Identification Division'].	self advance.	self consumeKeyword: 'DIVISION'.	self consumePeriod.	"Mandatory PROGRAM-ID paragraph."	node programId: self parseProgramIdParagraph.	"Zero or more optional paragraphs, in any order."	[self isOptionalIdDivisionParagraphHeader]		whileTrue: [self parseOptionalIdDivisionParagraph: node].	^node</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseEnvironmentDivision">parseEnvironmentDivision	"Parse the Environment Division and return a CobolEnvironmentDivision node.	 Grammar:	   env-div ::= ENVIRONMENT DIVISION .	               [ configuration-section ]	               [ input-output-section ]	"	| node |	node := CobolEnvironmentDivision new.	(self currentIsKeyword: 'ENVIRONMENT') ifFalse: [^node].	self consumeKeyword: 'ENVIRONMENT'.	self consumeKeyword: 'DIVISION'.	self consumePeriod.	(self currentIsKeyword: 'CONFIGURATION')		ifTrue: [node configurationSection: self parseConfigurationSection].	(self currentIsKeyword: 'INPUT-OUTPUT')		ifTrue: [node inputOutputSection: self parseInputOutputSection].	^node</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDataDivision">parseDataDivision	"Parse the Data Division and return a CobolDataDivision node.	 Grammar:	   data-div ::= DATA DIVISION .	                [ file-section ]	                [ working-storage-section ]	                [ local-storage-section ]	                [ linkage-section ]	                [ communication-section ]	                [ report-section ]	                [ screen-section ]	"	| div |	div := CobolDataDivision new.	self consumeKeyword: 'DATA'.	self consumeKeyword: 'DIVISION'.	self consumePeriod.	[ self isDataDivisionSectionHeader ] whileTrue: [		(self currentIsKeyword: 'FILE') ifTrue: [			div fileSection: self parseFileSection ].		(self currentIsKeyword: 'WORKING-STORAGE') ifTrue: [			div workingStorageSection: self parseWorkingStorageSection ].		(self currentIsKeyword: 'LOCAL-STORAGE') ifTrue: [			div localStorageSection: self parseLocalStorageSection ].		(self currentIsKeyword: 'LINKAGE') ifTrue: [			div linkageSection: self parseLinkageSection ].		(self currentIsKeyword: 'COMMUNICATION') ifTrue: [			div communicationSection: self parseCommunicationSection ].		(self currentIsKeyword: 'REPORT') ifTrue: [			div reportSection: self parseReportSection ].		(self currentIsKeyword: 'SCREEN') ifTrue: [			div screenSection: self parseScreenSection ] ].	^ div</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDataDivision">parseDataDivision	"Parse the Data Division and return a CobolDataDivision node.	 Grammar:	   data-div ::= DATA DIVISION .	                [ file-section ]	                [ working-storage-section ]	                [ local-storage-section ]	                [ linkage-section ]	                [ communication-section ]	                [ report-section ]	                [ screen-section ]	"	| div |	div := CobolDataDivision new.	self consumeKeyword: 'DATA'.	self consumeKeyword: 'DIVISION'.	self consumePeriod.	[self isDataDivisionSectionHeader] whileTrue: 			[(self currentIsKeyword: 'FILE')				ifTrue: [div fileSection: self parseFileSection].			(self currentIsKeyword: 'WORKING-STORAGE')				ifTrue: [div workingStorageSection: self parseWorkingStorageSection].			(self currentIsKeyword: 'LOCAL-STORAGE')				ifTrue: [div localStorageSection: self parseLocalStorageSection].			(self currentIsKeyword: 'LINKAGE')				ifTrue: [div linkageSection: self parseLinkageSection].			(self currentIsKeyword: 'COMMUNICATION')				ifTrue: [div communicationSection: self parseCommunicationSection].			(self currentIsKeyword: 'REPORT')				ifTrue: [div reportSection: self parseReportSection].			(self currentIsKeyword: 'SCREEN')				ifTrue: [div screenSection: self parseScreenSection]].	^div</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseProcedureDivision">parseProcedureDivision	self log: 'parseProcedureDivision'</body></methods><class><name>CobolProgramIdParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseProgramIdParagraph">parseProgramIdParagraph	"Parse: PROGRAM-ID . program-name [IS [INITIAL|RECURSIVE|COMMON] PROGRAM] .	 Returns a CobolProgramIdParagraph."	| name programType |	self consumeKeyword: 'PROGRAM-ID'.	self consumePeriod.	"The program name may be a plain identifier or a keyword used as a name."	name := self consumeName.	"Optional attribute clause: IS [INITIAL | RECURSIVE | COMMON] [PROGRAM]"	programType := #normal.	(self currentIsKeyword: 'IS') ifTrue: [		self advance.		(self currentIsKeyword: 'INITIAL')			ifTrue: [				programType := #initial.				self advance ]			ifFalse: [				(self currentIsKeyword: 'RECURSIVE')					ifTrue: [						programType := #recursive.						self advance ]					ifFalse: [						(self currentIsKeyword: 'COMMON')							ifTrue: [								programType := #common.								self advance ]							ifFalse: [								self error:									'Expected INITIAL, RECURSIVE, or COMMON after IS in PROGRAM-ID' ] ] ].		"Optional trailing PROGRAM keyword."		(self currentIsKeyword: 'PROGRAM') ifTrue: [ self advance ] ].	self currentIsPeriod ifTrue: [ self consumePeriod ].	^ CobolProgramIdParagraph name: name programType: programType</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseProgramIdParagraph">parseProgramIdParagraph	"Parse: PROGRAM-ID . program-name [IS [INITIAL|RECURSIVE|COMMON] PROGRAM] .	 Returns a CobolProgramIdParagraph."	| name programType |	self consumeKeyword: 'PROGRAM-ID'.	self consumePeriod.	"The program name may be a plain identifier or a keyword used as a name."	name := self consumeName.	"Optional attribute clause: IS [INITIAL | RECURSIVE | COMMON] [PROGRAM]"	programType := #normal.	(self currentIsKeyword: 'IS')		ifTrue: 			[self advance.			(self currentIsKeyword: 'INITIAL')				ifTrue: 					[programType := #initial.					self advance]				ifFalse: 					[(self currentIsKeyword: 'RECURSIVE')						ifTrue: 							[programType := #recursive.							self advance]						ifFalse: 							[(self currentIsKeyword: 'COMMON')								ifTrue: 									[programType := #common.									self advance]								ifFalse: 									[self										error: 'Expected INITIAL, RECURSIVE, or COMMON after IS in PROGRAM-ID']]].			"Optional trailing PROGRAM keyword."			(self currentIsKeyword: 'PROGRAM') ifTrue: [self advance]].	self currentIsPeriod ifTrue: [self consumePeriod].	^CobolProgramIdParagraph name: name programType: programType</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="isOptionalIdDivisionParagraphHeader">isOptionalIdDivisionParagraphHeader	"True when the current token begins one of the optional ID division paragraphs."	^ (self currentIsKeyword: 'AUTHOR') or: [		  (self currentIsKeyword: 'INSTALLATION') or: [			  (self currentIsKeyword: 'DATE-WRITTEN') or: [				  (self currentIsKeyword: 'DATE-COMPILED') or: [					  self currentIsKeyword: 'SECURITY' ] ] ] ]</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="isOptionalIdDivisionParagraphHeader">isOptionalIdDivisionParagraphHeader	"True when the current token begins one of the optional ID division paragraphs."	^(self currentIsKeyword: 'AUTHOR') or: 			[(self currentIsKeyword: 'INSTALLATION') or: 					[(self currentIsKeyword: 'DATE-WRITTEN') or: 							[(self currentIsKeyword: 'DATE-COMPILED')								or: [self currentIsKeyword: 'SECURITY']]]]</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseOptionalIdDivisionParagraph:">parseOptionalIdDivisionParagraph: aNode	"Parse one optional ID division paragraph (AUTHOR, INSTALLATION, etc.)	 and populate the corresponding slot of aNode.	 Grammar:	   optional-para ::= paragraph-keyword . comment-entry	   comment-entry ::= { any-token } *  (terminated by period or next paragraph)	"	| keyword text |	keyword := currentToken value asUppercase.	self advance.	self consumePeriod.	text := self parseCommentEntry.	keyword = 'AUTHOR' ifTrue: [ aNode author: text ].	keyword = 'INSTALLATION' ifTrue: [ aNode installation: text ].	keyword = 'DATE-WRITTEN' ifTrue: [ aNode dateWritten: text ].	keyword = 'DATE-COMPILED' ifTrue: [ aNode dateCompiled: text ].	keyword = 'SECURITY' ifTrue: [ aNode security: text ]</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseOptionalIdDivisionParagraph:">parseOptionalIdDivisionParagraph: aNode	"Parse one optional ID division paragraph (AUTHOR, INSTALLATION, etc.)	 and populate the corresponding slot of aNode.	 Grammar:	   optional-para ::= paragraph-keyword . comment-entry	   comment-entry ::= { any-token } *  (terminated by period or next paragraph)	"	| keyword text |	keyword := currentToken value asUppercase.	self advance.	self consumePeriod.	text := self parseCommentEntry.	keyword = 'AUTHOR' ifTrue: [aNode author: text].	keyword = 'INSTALLATION' ifTrue: [aNode installation: text].	keyword = 'DATE-WRITTEN' ifTrue: [aNode dateWritten: text].	keyword = 'DATE-COMPILED' ifTrue: [aNode dateCompiled: text].	keyword = 'SECURITY' ifTrue: [aNode security: text]</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseCommentEntry">parseCommentEntry	"Collect all tokens up to (but not including) the terminating period,	 the next optional-paragraph header, a later division header, or EOF.	 The terminating period is consumed.	 Returns the collected text as a single String."	| parts |	parts := OrderedCollection new.	[	((((self currentIsEof or: [ self currentIsPeriod ]) or: [		   self isOptionalIdDivisionParagraphHeader ]) or: [		  self currentIsKeyword: 'ENVIRONMENT' ]) or: [		 self currentIsKeyword: 'DATA' ]) or: [		self currentIsKeyword: 'PROCEDURE' ] ] whileFalse: [		parts add: currentToken value asString.		self advance ].	"Consume the period that closed this paragraph, if present."	self currentIsPeriod ifTrue: [ self advance ].	^ String streamContents: [ :s |		  parts doWithIndex: [ :each :i |			  i &gt; 1 ifTrue: [ s space ].			  s nextPutAll: each ] ]</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseCommentEntry">parseCommentEntry	"Collect all tokens up to (but not including) the terminating period,	 the next optional-paragraph header, a later division header, or EOF.	 The terminating period is consumed.	 Returns the collected text as a single String."	| parts |	parts := OrderedCollection new.		[((((self currentIsEof or: [self currentIsPeriod])		or: [self isOptionalIdDivisionParagraphHeader])			or: [self currentIsKeyword: 'ENVIRONMENT'])			or: [self currentIsKeyword: 'DATA'])			or: [self currentIsKeyword: 'PROCEDURE']]			whileFalse: 				[parts add: currentToken value asString.				self advance].	"Consume the period that closed this paragraph, if present."	self currentIsPeriod ifTrue: [self advance].	^String streamContents: 			[:s |			parts doWithIndex: 					[:each :i |					i &gt; 1 ifTrue: [s space].					s nextPutAll: each]]</body></methods><class><name>CobolConfigurationSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolConfigurationSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseConfigurationSection">parseConfigurationSection	"Parse: CONFIGURATION SECTION . [ source-computer ] [ object-computer ] [ special-names ]	 Returns a CobolConfigurationSection."	| section |	section := CobolConfigurationSection new.	self consumeKeyword: 'CONFIGURATION'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	"Paragraphs may appear in any order."	[ self isConfigurationSectionParagraphHeader ] whileTrue: [		(self currentIsKeyword: 'SOURCE-COMPUTER') ifTrue: [			section sourceComputer: self parseSourceComputerParagraph ].		(self currentIsKeyword: 'OBJECT-COMPUTER') ifTrue: [			section objectComputer: self parseObjectComputerParagraph ].		(self currentIsKeyword: 'SPECIAL-NAMES') ifTrue: [			section specialNames: self parseSpecialNamesParagraph ] ].	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseConfigurationSection">parseConfigurationSection	"Parse: CONFIGURATION SECTION . [ source-computer ] [ object-computer ] [ special-names ]	 Returns a CobolConfigurationSection."	| section |	section := CobolConfigurationSection new.	self consumeKeyword: 'CONFIGURATION'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	"Paragraphs may appear in any order."	[self isConfigurationSectionParagraphHeader] whileTrue: 			[(self currentIsKeyword: 'SOURCE-COMPUTER')				ifTrue: [section sourceComputer: self parseSourceComputerParagraph].			(self currentIsKeyword: 'OBJECT-COMPUTER')				ifTrue: [section objectComputer: self parseObjectComputerParagraph].			(self currentIsKeyword: 'SPECIAL-NAMES')				ifTrue: [section specialNames: self parseSpecialNamesParagraph]].	^section</body></methods><class><name>CobolSourceComputerParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolSourceComputerParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '10:35:42 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 10:35:42 AM on April 8, 2026."</do-it><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSourceComputerParagraph">parseSourceComputerParagraph	"Parse: SOURCE-COMPUTER . [computer-name [WITH DEBUGGING MODE]] .	 Returns a CobolSourceComputerParagraph."	| para |	para := CobolSourceComputerParagraph new.	self consumeKeyword: 'SOURCE-COMPUTER'.	self consumePeriod.	"Optional body — absent when the paragraph is immediately followed by another header."	(self currentIsPeriod or: [		 self isConfigurationSectionParagraphHeader or: [			 self isEnvironmentDivisionSectionHeader or: [				 self isDivisionHeader ] ] ]) ifFalse: [		para computerName: self consumeName.		(self currentIsKeyword: 'WITH') ifTrue: [			self advance.			self consumeKeyword: 'DEBUGGING'.			self consumeKeyword: 'MODE'.			para debuggingMode: true ] ].	self currentIsPeriod ifTrue: [ self advance ].	^ para</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSourceComputerParagraph">parseSourceComputerParagraph	"Parse: SOURCE-COMPUTER . [computer-name [WITH DEBUGGING MODE]] .	 Returns a CobolSourceComputerParagraph."	| para |	para := CobolSourceComputerParagraph new.	self consumeKeyword: 'SOURCE-COMPUTER'.	self consumePeriod.	"Optional body — absent when the paragraph is immediately followed by another header."	(self currentIsPeriod or: 			[self isConfigurationSectionParagraphHeader				or: [self isEnvironmentDivisionSectionHeader or: [self isDivisionHeader]]])		ifFalse: 			[para computerName: self consumeName.			(self currentIsKeyword: 'WITH')				ifTrue: 					[self advance.					self consumeKeyword: 'DEBUGGING'.					self consumeKeyword: 'MODE'.					para debuggingMode: true]].	self currentIsPeriod ifTrue: [self advance].	^para</body></methods><class><name>CobolObjectComputerParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolObjectComputerParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolObjectComputerParagraph</class-id> <category>As yet unclassified</category><body package="CobolStudio" selector="parseObjectComputerParagraph">parseObjectComputerParagraph	"Parse: OBJECT-COMPUTER . [computer-name clause*] .	 Returns a CobolObjectComputerParagraph.	 Optional clauses (any order):	   MEMORY SIZE integer (WORDS|CHARACTERS|MODULES)	   PROGRAM COLLATING SEQUENCE [IS] alphabet-name	   SEGMENT-LIMIT IS segment-number	   CHARACTER SET [IS] alphabet-name	"	| para |	para := CobolObjectComputerParagraph new.	self consumeKeyword: 'OBJECT-COMPUTER'.	self consumePeriod.	"Optional body."	(self currentIsPeriod or: [		 self isConfigurationSectionParagraphHeader or: [			 self isEnvironmentDivisionSectionHeader or: [				 self isDivisionHeader ] ] ]) ifFalse: [		para computerName: self consumeName.		[		self currentIsPeriod or: [			self isConfigurationSectionParagraphHeader or: [				self isEnvironmentDivisionSectionHeader or: [					self isDivisionHeader ] ] ] ] whileFalse: [			self parseObjectComputerClause: para ] ].	self currentIsPeriod ifTrue: [ self advance ].	^ para</body></methods><methods><class-id>CobolObjectComputerParagraph</class-id> <category>As yet unclassified</category><body package="CobolStudio" selector="parseObjectComputerParagraph">parseObjectComputerParagraph	"Parse: OBJECT-COMPUTER . [computer-name clause*] .	 Returns a CobolObjectComputerParagraph.	 Optional clauses (any order):	   MEMORY SIZE integer (WORDS|CHARACTERS|MODULES)	   PROGRAM COLLATING SEQUENCE [IS] alphabet-name	   SEGMENT-LIMIT IS segment-number	   CHARACTER SET [IS] alphabet-name	"	| para |	para := CobolObjectComputerParagraph new.	self consumeKeyword: 'OBJECT-COMPUTER'.	self consumePeriod.	"Optional body."	(self currentIsPeriod or: 			[self isConfigurationSectionParagraphHeader				or: [self isEnvironmentDivisionSectionHeader or: [self isDivisionHeader]]])		ifFalse: 			[para computerName: self consumeName.						[self currentIsPeriod or: 					[self isConfigurationSectionParagraphHeader						or: [self isEnvironmentDivisionSectionHeader or: [self isDivisionHeader]]]]					whileFalse: [self parseObjectComputerClause: para]].	self currentIsPeriod ifTrue: [self advance].	^para</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseObjectComputerClause:">parseObjectComputerClause: aParagraph	"Parse one optional clause of the OBJECT-COMPUTER paragraph."	"MEMORY SIZE integer (WORDS|CHARACTERS|MODULES)"	(self currentIsKeyword: 'MEMORY') ifTrue: [		self advance.		(self currentIsKeyword: 'SIZE') ifTrue: [ self advance ].		aParagraph memorySizeAmount: currentToken value.		self advance.		(self currentIsKeyword: 'WORDS')			ifTrue: [				aParagraph memorySizeUnit: #words.				self advance ]			ifFalse: [				(self currentIsKeyword: 'CHARACTERS')					ifTrue: [						aParagraph memorySizeUnit: #characters.						self advance ]					ifFalse: [						(self currentIsKeyword: 'MODULES') ifTrue: [							aParagraph memorySizeUnit: #modules.							self advance ] ] ].		^ self ].	"PROGRAM COLLATING SEQUENCE [IS] alphabet-name"	(self currentIsKeyword: 'PROGRAM') ifTrue: [		self advance.		self consumeKeyword: 'COLLATING'.		self consumeKeyword: 'SEQUENCE'.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		aParagraph sequenceAlphabetName: self consumeName.		^ self ].	"SEGMENT-LIMIT IS segment-number"	(self currentIsKeyword: 'SEGMENT-LIMIT') ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		aParagraph segmentLimitSegmentNumber: currentToken value.		self advance.		^ self ].	"CHARACTER SET [IS] alphabet-name"	(self currentIsKeyword: 'CHARACTER') ifTrue: [		self advance.		(self currentIsKeyword: 'SET') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		aParagraph characterSetAlphabetName: self consumeName.		^ self ].	"Unknown clause token — skip it to avoid looping."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseObjectComputerClause:">parseObjectComputerClause: aParagraph	"Parse one optional clause of the OBJECT-COMPUTER paragraph."	"MEMORY SIZE integer (WORDS|CHARACTERS|MODULES)"	(self currentIsKeyword: 'MEMORY')		ifTrue: 			[self advance.			(self currentIsKeyword: 'SIZE') ifTrue: [self advance].			aParagraph memorySizeAmount: currentToken value.			self advance.			(self currentIsKeyword: 'WORDS')				ifTrue: 					[aParagraph memorySizeUnit: #words.					self advance]				ifFalse: 					[(self currentIsKeyword: 'CHARACTERS')						ifTrue: 							[aParagraph memorySizeUnit: #characters.							self advance]						ifFalse: 							[(self currentIsKeyword: 'MODULES')								ifTrue: 									[aParagraph memorySizeUnit: #modules.									self advance]]].			^self].	"PROGRAM COLLATING SEQUENCE [IS] alphabet-name"	(self currentIsKeyword: 'PROGRAM')		ifTrue: 			[self advance.			self consumeKeyword: 'COLLATING'.			self consumeKeyword: 'SEQUENCE'.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			aParagraph sequenceAlphabetName: self consumeName.			^self].	"SEGMENT-LIMIT IS segment-number"	(self currentIsKeyword: 'SEGMENT-LIMIT')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			aParagraph segmentLimitSegmentNumber: currentToken value.			self advance.			^self].	"CHARACTER SET [IS] alphabet-name"	(self currentIsKeyword: 'CHARACTER')		ifTrue: 			[self advance.			(self currentIsKeyword: 'SET') ifTrue: [self advance].			(self currentIsKeyword: 'IS') ifTrue: [self advance].			aParagraph characterSetAlphabetName: self consumeName.			^self].	"Unknown clause token — skip it to avoid looping."	self advance</body></methods><class><name>CobolSpecialNamesParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolSpecialNamesParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSpecialNamesParagraph">parseSpecialNamesParagraph	"Parse: SPECIAL-NAMES . clause* .	 Returns a CobolSpecialNamesParagraph."	| para |	para := CobolSpecialNamesParagraph new.	self consumeKeyword: 'SPECIAL-NAMES'.	self consumePeriod.	[	self currentIsPeriod or: [		self isConfigurationSectionParagraphHeader or: [			self isEnvironmentDivisionSectionHeader or: [				self isDivisionHeader or: [ self currentIsEof ] ] ] ] ]		whileFalse: [ self parseSpecialNamesClause: para ].	self currentIsPeriod ifTrue: [ self advance ].	^ para</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSpecialNamesParagraph">parseSpecialNamesParagraph	"Parse: SPECIAL-NAMES . clause* .	 Returns a CobolSpecialNamesParagraph."	| para |	para := CobolSpecialNamesParagraph new.	self consumeKeyword: 'SPECIAL-NAMES'.	self consumePeriod.		[self currentIsPeriod or: 			[self isConfigurationSectionParagraphHeader or: 					[self isEnvironmentDivisionSectionHeader						or: [self isDivisionHeader or: [self currentIsEof]]]]]			whileFalse: [self parseSpecialNamesClause: para].	self currentIsPeriod ifTrue: [self advance].	^para</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSpecialNamesClause:">parseSpecialNamesClause: aParagraph	"Dispatch to the correct SPECIAL-NAMES clause parser."	"ALPHABET alphabet-name IS ..."	(self currentIsKeyword: 'ALPHABET') ifTrue: [		aParagraph alphabets add: self parseAlphabetClause.		^ self ].	"SYMBOLIC CHARACTERS ..."	(self currentIsKeyword: 'SYMBOLIC') ifTrue: [		aParagraph symbolicCharacters add:			self parseSymbolicCharactersClause.		^ self ].	"CLASS class-name IS ..."	(self currentIsKeyword: 'CLASS') ifTrue: [		aParagraph classes add: self parseClassClause.		^ self ].	"CURRENCY SIGN IS literal"	(self currentIsKeyword: 'CURRENCY') ifTrue: [		self advance.		(self currentIsKeyword: 'SIGN') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		aParagraph currencySign: currentToken value.		self advance.		^ self ].	"DECIMAL-POINT IS COMMA"	(self currentIsKeyword: 'DECIMAL-POINT') ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		self consumeKeyword: 'COMMA'.		aParagraph decimalPointIsComma: true.		^ self ].	"system-name IS mnemonic-name [ON/OFF STATUS IS condition-name]"	self currentIsName ifTrue: [		aParagraph mnemonicNames add: self parseMnemonicNameClause.		^ self ].	"Unrecognised token — skip to avoid infinite loop."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSpecialNamesClause:">parseSpecialNamesClause: aParagraph	"Dispatch to the correct SPECIAL-NAMES clause parser."	"ALPHABET alphabet-name IS ..."	(self currentIsKeyword: 'ALPHABET')		ifTrue: 			[aParagraph alphabets add: self parseAlphabetClause.			^self].	"SYMBOLIC CHARACTERS ..."	(self currentIsKeyword: 'SYMBOLIC')		ifTrue: 			[aParagraph symbolicCharacters add: self parseSymbolicCharactersClause.			^self].	"CLASS class-name IS ..."	(self currentIsKeyword: 'CLASS')		ifTrue: 			[aParagraph classes add: self parseClassClause.			^self].	"CURRENCY SIGN IS literal"	(self currentIsKeyword: 'CURRENCY')		ifTrue: 			[self advance.			(self currentIsKeyword: 'SIGN') ifTrue: [self advance].			(self currentIsKeyword: 'IS') ifTrue: [self advance].			aParagraph currencySign: currentToken value.			self advance.			^self].	"DECIMAL-POINT IS COMMA"	(self currentIsKeyword: 'DECIMAL-POINT')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			self consumeKeyword: 'COMMA'.			aParagraph decimalPointIsComma: true.			^self].	"system-name IS mnemonic-name [ON/OFF STATUS IS condition-name]"	self currentIsName		ifTrue: 			[aParagraph mnemonicNames add: self parseMnemonicNameClause.			^self].	"Unrecognised token — skip to avoid infinite loop."	self advance</body></methods><class><name>CobolMnemonicNameClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolMnemonicNameClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseMnemonicNameClause">parseMnemonicNameClause	"Parse: system-name IS mnemonic-name	          [ON  STATUS IS condition-name]	          [OFF STATUS IS condition-name]	 Returns a CobolMnemonicNameClause."	| clause |	clause := CobolMnemonicNameClause new.	clause systemName: self consumeName.	(self currentIsKeyword: 'IS') ifTrue: [ self advance ].	clause mnemonicName: self consumeName.	"Optional ON/OFF STATUS clauses, in either order."	2 timesRepeat: [		(self currentIsKeyword: 'ON') ifTrue: [			self advance.			(self currentIsKeyword: 'STATUS') ifTrue: [ self advance ].			(self currentIsKeyword: 'IS') ifTrue: [ self advance ].			clause onStatusCondition: self consumeName ].		(self currentIsKeyword: 'OFF') ifTrue: [			self advance.			(self currentIsKeyword: 'STATUS') ifTrue: [ self advance ].			(self currentIsKeyword: 'IS') ifTrue: [ self advance ].			clause offStatusCondition: self consumeName ] ].	^ clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseMnemonicNameClause">parseMnemonicNameClause	"Parse: system-name IS mnemonic-name	          [ON  STATUS IS condition-name]	          [OFF STATUS IS condition-name]	 Returns a CobolMnemonicNameClause."	| clause |	clause := CobolMnemonicNameClause new.	clause systemName: self consumeName.	(self currentIsKeyword: 'IS') ifTrue: [self advance].	clause mnemonicName: self consumeName.	"Optional ON/OFF STATUS clauses, in either order."	2 timesRepeat: 			[(self currentIsKeyword: 'ON')				ifTrue: 					[self advance.					(self currentIsKeyword: 'STATUS') ifTrue: [self advance].					(self currentIsKeyword: 'IS') ifTrue: [self advance].					clause onStatusCondition: self consumeName].			(self currentIsKeyword: 'OFF')				ifTrue: 					[self advance.					(self currentIsKeyword: 'STATUS') ifTrue: [self advance].					(self currentIsKeyword: 'IS') ifTrue: [self advance].					clause offStatusCondition: self consumeName]].	^clause</body></methods><class><name>CobolAlphabetClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolAlphabetClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>As yet unclassified</category><body package="CobolStudio" selector="parseAlphabetClause">parseAlphabetClause	"Parse: ALPHABET alphabet-name IS	          { STANDARD-1 | STANDARD-2 | NATIVE | EBCDIC |	            literal [{THROUGH|THRU} literal | {ALSO literal}...] ... }	 Returns a CobolAlphabetClause."	| clause |	clause := CobolAlphabetClause new.	self consumeKeyword: 'ALPHABET'.	clause alphabetName: self consumeName.	(self currentIsKeyword: 'IS') ifTrue: [ self advance ].	(self currentIsKeyword: 'STANDARD-1') ifTrue: [		clause alphabetType: #standard1.		self advance.		^ clause ].	(self currentIsKeyword: 'STANDARD-2') ifTrue: [		clause alphabetType: #standard2.		self advance.		^ clause ].	(self currentIsKeyword: 'NATIVE') ifTrue: [		clause alphabetType: #native.		self advance.		^ clause ].	(self currentIsKeyword: 'EBCDIC') ifTrue: [		clause alphabetType: #ebcdic.		self advance.		^ clause ].	"Custom character list."	clause alphabetType: #custom.	[	self currentIsPeriod or: [		self isConfigurationSectionParagraphHeader or: [			self isEnvironmentDivisionSectionHeader or: [				self isDivisionHeader or: [					self currentIsEof or: [						(self currentIsKeyword: 'ALPHABET') or: [							self currentIsKeyword: 'SYMBOLIC' or: [								(self currentIsKeyword: 'CLASS') or: [									self										currentIsKeyword: 'CURRENCY'										or: [ self currentIsKeyword: 'DECIMAL-POINT' ] ] ] ] ] ] ] ] ] ]		whileFalse: [			| from to |			from := currentToken value.			self advance.			((self currentIsKeyword: 'THROUGH') or: [				 self currentIsKeyword: 'THRU' ])				ifTrue: [					self advance.					to := currentToken value.					self advance ]				ifFalse: [ to := from ].			clause characterRanges add: from -&gt; to.			"Consume optional ALSO literals."			[ self currentIsKeyword: 'ALSO' ] whileTrue: [				self advance.				clause characterRanges add:					currentToken value -&gt; currentToken value.				self advance ] ].	^ clause</body></methods><methods><class-id>CobolParser</class-id> <category>As yet unclassified</category><body package="CobolStudio" selector="parseAlphabetClause">parseAlphabetClause	"Parse: ALPHABET alphabet-name IS	          { STANDARD-1 | STANDARD-2 | NATIVE | EBCDIC |	            literal [{THROUGH|THRU} literal | {ALSO literal}...] ... }	 Returns a CobolAlphabetClause."	| clause |	clause := CobolAlphabetClause new.	self consumeKeyword: 'ALPHABET'.	clause alphabetName: self consumeName.	(self currentIsKeyword: 'IS') ifTrue: [self advance].	(self currentIsKeyword: 'STANDARD-1')		ifTrue: 			[clause alphabetType: #standard1.			self advance.			^clause].	(self currentIsKeyword: 'STANDARD-2')		ifTrue: 			[clause alphabetType: #standard2.			self advance.			^clause].	(self currentIsKeyword: 'NATIVE')		ifTrue: 			[clause alphabetType: #native.			self advance.			^clause].	(self currentIsKeyword: 'EBCDIC')		ifTrue: 			[clause alphabetType: #ebcdic.			self advance.			^clause].	"Custom character list."	clause alphabetType: #custom.		[self currentIsPeriod or: 			[self isConfigurationSectionParagraphHeader or: 					[self isEnvironmentDivisionSectionHeader or: 							[self isDivisionHeader or: 									[self currentIsEof or: 											[(self currentIsKeyword: 'ALPHABET') or: 													[self currentIsKeyword: 'SYMBOLIC'														or: 															[(self currentIsKeyword: 'CLASS') or: 																	[self currentIsKeyword: 'CURRENCY'																		or: [self currentIsKeyword: 'DECIMAL-POINT']]]]]]]]]]			whileFalse: 				[| from to |				from := currentToken value.				self advance.				((self currentIsKeyword: 'THROUGH') or: [self currentIsKeyword: 'THRU'])					ifTrue: 						[self advance.						to := currentToken value.						self advance]					ifFalse: [to := from].				clause characterRanges add: from -&gt; to.				"Consume optional ALSO literals."				[self currentIsKeyword: 'ALSO'] whileTrue: 						[self advance.						clause characterRanges add: currentToken value -&gt; currentToken value.						self advance]].	^clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseAlphabetClause">parseAlphabetClause	"Parse: ALPHABET alphabet-name IS	          { STANDARD-1 | STANDARD-2 | NATIVE | EBCDIC |	            literal [{THROUGH|THRU} literal | {ALSO literal}...] ... }	 Returns a CobolAlphabetClause."	| clause |	clause := CobolAlphabetClause new.	self consumeKeyword: 'ALPHABET'.	clause alphabetName: self consumeName.	(self currentIsKeyword: 'IS') ifTrue: [self advance].	(self currentIsKeyword: 'STANDARD-1')		ifTrue: 			[clause alphabetType: #standard1.			self advance.			^clause].	(self currentIsKeyword: 'STANDARD-2')		ifTrue: 			[clause alphabetType: #standard2.			self advance.			^clause].	(self currentIsKeyword: 'NATIVE')		ifTrue: 			[clause alphabetType: #native.			self advance.			^clause].	(self currentIsKeyword: 'EBCDIC')		ifTrue: 			[clause alphabetType: #ebcdic.			self advance.			^clause].	"Custom character list."	clause alphabetType: #custom.		[self currentIsPeriod or: 			[self isConfigurationSectionParagraphHeader or: 					[self isEnvironmentDivisionSectionHeader or: 							[self isDivisionHeader or: 									[self currentIsEof or: 											[(self currentIsKeyword: 'ALPHABET') or: 													[self currentIsKeyword: 'SYMBOLIC'														or: 															[(self currentIsKeyword: 'CLASS') or: 																	[self currentIsKeyword: 'CURRENCY'																		or: [self currentIsKeyword: 'DECIMAL-POINT']]]]]]]]]]			whileFalse: 				[| from to |				from := currentToken value.				self advance.				((self currentIsKeyword: 'THROUGH') or: [self currentIsKeyword: 'THRU'])					ifTrue: 						[self advance.						to := currentToken value.						self advance]					ifFalse: [to := from].				clause characterRanges add: from -&gt; to.				"Consume optional ALSO literals."				[self currentIsKeyword: 'ALSO'] whileTrue: 						[self advance.						clause characterRanges add: currentToken value -&gt; currentToken value.						self advance]].	^clause</body></methods><class><name>CobolSymbolicCharactersClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolSymbolicCharactersClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSymbolicCharactersClause">parseSymbolicCharactersClause	"Parse: SYMBOLIC CHARACTERS	          {symbolic-character... {ARE|IS} integer...}... [IN alphabet-name]	 Returns a CobolSymbolicCharactersClause."	| clause |	clause := CobolSymbolicCharactersClause new.	self consumeKeyword: 'SYMBOLIC'.	(self currentIsKeyword: 'CHARACTERS') ifTrue: [ self advance ].	"Collect name/ordinal pairs."	[	self currentIsName and: [		(self currentIsKeyword: 'IN') not and: [			(self currentIsKeyword: 'ALPHABET') not and: [				(self currentIsKeyword: 'CLASS') not and: [					(self currentIsKeyword: 'CURRENCY') not and: [						(self currentIsKeyword: 'DECIMAL-POINT') not ] ] ] ] ] ]		whileTrue: [ "One or more symbolic character names."			[			self currentIsName and: [				(self currentIsKeyword: 'ARE') not and: [					(self currentIsKeyword: 'IS') not and: [						(self currentIsKeyword: 'IN') not ] ] ] ] whileTrue: [				clause characterNames add: self consumeName ].			(self currentIsKeyword: 'ARE')				ifTrue: [ self advance ]				ifFalse: [ (self currentIsKeyword: 'IS') ifTrue: [ self advance ] ].			"Corresponding ordinal values."			[ currentToken isInteger ] whileTrue: [				clause ordinalValues add: currentToken value.				self advance ] ].	"Optional IN alphabet-name."	(self currentIsKeyword: 'IN') ifTrue: [		self advance.		clause alphabetName: self consumeName ].	^ clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSymbolicCharactersClause">parseSymbolicCharactersClause	"Parse: SYMBOLIC CHARACTERS	          {symbolic-character... {ARE|IS} integer...}... [IN alphabet-name]	 Returns a CobolSymbolicCharactersClause."	| clause |	clause := CobolSymbolicCharactersClause new.	self consumeKeyword: 'SYMBOLIC'.	(self currentIsKeyword: 'CHARACTERS') ifTrue: [self advance].	"Collect name/ordinal pairs."		[self currentIsName and: 			[(self currentIsKeyword: 'IN') not and: 					[(self currentIsKeyword: 'ALPHABET') not and: 							[(self currentIsKeyword: 'CLASS') not and: 									[(self currentIsKeyword: 'CURRENCY') not										and: [(self currentIsKeyword: 'DECIMAL-POINT') not]]]]]]			whileTrue: 				["One or more symbolic character names."								[self currentIsName and: 						[(self currentIsKeyword: 'ARE') not and: 								[(self currentIsKeyword: 'IS') not and: [(self currentIsKeyword: 'IN') not]]]]						whileTrue: [clause characterNames add: self consumeName].				(self currentIsKeyword: 'ARE')					ifTrue: [self advance]					ifFalse: [(self currentIsKeyword: 'IS') ifTrue: [self advance]].				"Corresponding ordinal values."				[currentToken isInteger] whileTrue: 						[clause ordinalValues add: currentToken value.						self advance]].	"Optional IN alphabet-name."	(self currentIsKeyword: 'IN')		ifTrue: 			[self advance.			clause alphabetName: self consumeName].	^clause</body></methods><class><name>CobolClassClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolClassClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseClassClause">parseClassClause	"Parse: CLASS class-name IS literal [{THROUGH|THRU} literal] ...	 Returns a CobolClassClause."	| clause |	clause := CobolClassClause new.	self consumeKeyword: 'CLASS'.	clause className: self consumeName.	(self currentIsKeyword: 'IS') ifTrue: [ self advance ].(   ((  (   ( (	(((self currentIsEof or: [ self currentIsPeriod])		or: [ self isConfigurationSectionParagraphHeader])		or: [ self isEnvironmentDivisionSectionHeader])		or: [ self isDivisionHeader ])		or: [ (self currentIsKeyword: 'ALPHABET')])		or: [ (self currentIsKeyword: 'SYMBOLIC')])		or: [ (self currentIsKeyword: 'CLASS')])		or: [ (self currentIsKeyword: 'CURRENCY')])		or: [ self currentIsKeyword: 'DECIMAL-POINT' ])  whileFalse: [		| from to |		from := currentToken value.		self advance.		((self currentIsKeyword: 'THROUGH') or: [ self currentIsKeyword: 'THRU' ]) ifTrue: [			self advance.			to := currentToken value.			self advance ]		ifFalse: [ to := from ].		clause characterRanges add: from -&gt; to ].	^ clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseClassClause">parseClassClause	"Parse: CLASS class-name IS literal [{THROUGH|THRU} literal] ...	 Returns a CobolClassClause."	| clause |	clause := CobolClassClause new.	self consumeKeyword: 'CLASS'.	clause className: self consumeName.	(self currentIsKeyword: 'IS') ifTrue: [self advance].	(((((((((self currentIsEof or: [self currentIsPeriod])		or: [self isConfigurationSectionParagraphHeader])			or: [self isEnvironmentDivisionSectionHeader]) or: [self isDivisionHeader])		or: [self currentIsKeyword: 'ALPHABET'])			or: [self currentIsKeyword: 'SYMBOLIC'])			or: [self currentIsKeyword: 'CLASS'])			or: [self currentIsKeyword: 'CURRENCY'])			or: [self currentIsKeyword: 'DECIMAL-POINT']) whileFalse: 				[| from to |				from := currentToken value.				self advance.				((self currentIsKeyword: 'THROUGH') or: [self currentIsKeyword: 'THRU'])					ifTrue: 						[self advance.						to := currentToken value.						self advance]					ifFalse: [to := from].				clause characterRanges add: from -&gt; to].	^clause</body></methods><class><name>CobolInputOutputSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolInputOutputSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseInputOutputSection">parseInputOutputSection	"Parse: INPUT-OUTPUT SECTION . [ file-control ] [ io-control ]	 Returns a CobolInputOutputSection."	| section |	section := CobolInputOutputSection new.	self consumeKeyword: 'INPUT-OUTPUT'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	(self currentIsKeyword: 'FILE-CONTROL') ifTrue: [		section fileControl: self parseFileControlParagraph ].	(self currentIsKeyword: 'I-O-CONTROL') ifTrue: [		section ioControl: self parseIoControlParagraph ].	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseInputOutputSection">parseInputOutputSection	"Parse: INPUT-OUTPUT SECTION . [ file-control ] [ io-control ]	 Returns a CobolInputOutputSection."	| section |	section := CobolInputOutputSection new.	self consumeKeyword: 'INPUT-OUTPUT'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	(self currentIsKeyword: 'FILE-CONTROL')		ifTrue: [section fileControl: self parseFileControlParagraph].	(self currentIsKeyword: 'I-O-CONTROL')		ifTrue: [section ioControl: self parseIoControlParagraph].	^section</body></methods><class><name>CobolFileControlParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolFileControlParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileControlParagraph">parseFileControlParagraph	"Parse: FILE-CONTROL . { SELECT entry } *	 Returns a CobolFileControlParagraph."	| para |	para := CobolFileControlParagraph new.	self consumeKeyword: 'FILE-CONTROL'.	self consumePeriod.	[ self currentIsKeyword: 'SELECT' ] whileTrue: [		para selectEntries add: self parseSelectEntry ].	^ para</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileControlParagraph">parseFileControlParagraph	"Parse: FILE-CONTROL . { SELECT entry } *	 Returns a CobolFileControlParagraph."	| para |	para := CobolFileControlParagraph new.	self consumeKeyword: 'FILE-CONTROL'.	self consumePeriod.	[self currentIsKeyword: 'SELECT']		whileTrue: [para selectEntries add: self parseSelectEntry].	^para</body></methods><class><name>CobolSelectEntry</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolSelectEntry</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSelectEntry">parseSelectEntry	"Parse one SELECT entry, terminated by a period.	 Returns a CobolSelectEntry.	 Grammar:	   SELECT [OPTIONAL] file-name	     ASSIGN TO {literal|data-name} ...	     [ORGANIZATION [IS] [LINE] SEQUENTIAL|RELATIVE|INDEXED]	     [ACCESS MODE [IS] SEQUENTIAL|RANDOM|DYNAMIC]	     [FILE STATUS [IS] data-name]	     [RELATIVE KEY [IS] data-name]	     [RECORD KEY [IS] data-name]	     [ALTERNATE RECORD KEY [IS] data-name [WITH DUPLICATES]]...	     [PADDING CHARACTER [IS] literal|data-name]	     [RECORD DELIMITER [IS] STANDARD-1|assignment-name]	     [RESERVE integer AREA[S]]	   .	"	| entry |	entry := CobolSelectEntry new.	self consumeKeyword: 'SELECT'.	(self currentIsKeyword: 'OPTIONAL') ifTrue: [		entry optional: true.		self advance ].	entry fileName: self consumeName.	[	(((self currentIsPeriod or: [ self currentIsEof ]) or: [		  self currentIsKeyword: 'SELECT' ]) or: [		 self isEnvironmentDivisionSectionHeader ]) or: [		self isDivisionHeader ] ] whileFalse: [		self parseSelectClause: entry ].	self currentIsPeriod ifTrue: [ self advance ].	^ entry</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSelectEntry">parseSelectEntry	"Parse one SELECT entry, terminated by a period.	 Returns a CobolSelectEntry.	 Grammar:	   SELECT [OPTIONAL] file-name	     ASSIGN TO {literal|data-name} ...	     [ORGANIZATION [IS] [LINE] SEQUENTIAL|RELATIVE|INDEXED]	     [ACCESS MODE [IS] SEQUENTIAL|RANDOM|DYNAMIC]	     [FILE STATUS [IS] data-name]	     [RELATIVE KEY [IS] data-name]	     [RECORD KEY [IS] data-name]	     [ALTERNATE RECORD KEY [IS] data-name [WITH DUPLICATES]]...	     [PADDING CHARACTER [IS] literal|data-name]	     [RECORD DELIMITER [IS] STANDARD-1|assignment-name]	     [RESERVE integer AREA[S]]	   .	"	| entry |	entry := CobolSelectEntry new.	self consumeKeyword: 'SELECT'.	(self currentIsKeyword: 'OPTIONAL')		ifTrue: 			[entry optional: true.			self advance].	entry fileName: self consumeName.		[(((self currentIsPeriod or: [self currentIsEof])		or: [self currentIsKeyword: 'SELECT'])			or: [self isEnvironmentDivisionSectionHeader]) or: [self isDivisionHeader]]			whileFalse: [self parseSelectClause: entry].	self currentIsPeriod ifTrue: [self advance].	^entry</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '10:47:03 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 10:47: