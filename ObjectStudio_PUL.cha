^ self locate: CobolToken eof ].	"Inline comment *&gt; — skip to end of line."	self isInlineCommentStart ifTrue: [		self skipToEndOfLine.		^ self nextToken ].	"Single-character punctuation."	self isPeriod ifTrue: [		self step.		^ self locate: CobolToken period ].	self isComma ifTrue: [		self step.		^ self locate: CobolToken comma ].	self isSemicolon ifTrue: [		self step.		^ self locate: CobolToken semicolon ].	self isLeftParen ifTrue: [		self step.		^ self locate: CobolToken leftParen ].	self isRightParen ifTrue: [		self step.		^ self locate: CobolToken rightParen ].	self isPlus ifTrue: [		self step.		^ self locate: CobolToken plus ].	self isEqual ifTrue: [		self step.		^ self locate: CobolToken equal ].	"Colon or :: (reference modification separator)."	self isColon ifTrue: [		self step.		self isColon ifTrue: [			self step.			^ self locate: CobolToken doubleColon ].		^ self locate: CobolToken colon ].	"Minus: operator (not part of an identifier here — identifiers start alpha)."	self isMinus ifTrue: [		self step.		^ self locate: CobolToken minus ].	"Asterisk or ** (exponentiation)."	self isAsterisk ifTrue: [		self step.		self isPeekAsterisk ifTrue: [			self step.			^ self locate: CobolToken exponent ].		^ self locate: CobolToken asterisk ].	"Slash."	self isSlash ifTrue: [		self step.		^ self locate: CobolToken slash ].	"Relational operators: &gt; &gt;= &lt; &lt;= &lt;&gt;."	self isGreater ifTrue: [		self step.		self isPeekEqual ifTrue: [			self step.			^ self locate: CobolToken greaterEqual ].		^ self locate: CobolToken greater ].	self isLess ifTrue: [		self step.		self isPeekEqual ifTrue: [			self step.			^ self locate: CobolToken lessEqual ].		self isPeekGreater ifTrue: [			self step.			^ self locate: CobolToken notEqual ].		^ self locate: CobolToken less ].	"Numeric literal (leading digit)."	self isDigit ifTrue: [ ^ self scanForNumber ].	"String literals."	self isDoubleQuote ifTrue: [ ^ self scanForString ].	self isSingleQuote ifTrue: [ ^ self scanForSingleQuotedString ].	"Identifier or keyword (must start with a letter)."	currentCharacter isLetter ifTrue: [ ^ self scanForIdentifier ].	"Picture starting with $"	self isDollar ifTrue: [ ^ self scanForPic ].	^ self locate: (CobolToken error: istream)</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="nextToken">nextToken	"Return the next token from the input stream."	self isEof ifTrue: [^self locate: CobolToken eof].	self skipWhitespace.	self isEof ifTrue: [^self locate: CobolToken eof].	"Inline comment *&gt; — skip to end of line."	self isInlineCommentStart		ifTrue: 			[self skipToEndOfLine.			^self nextToken].	"Single-character punctuation."	self isPeriod		ifTrue: 			[self step.			^self locate: CobolToken period].	self isComma		ifTrue: 			[self step.			^self locate: CobolToken comma].	self isSemicolon		ifTrue: 			[self step.			^self locate: CobolToken semicolon].	self isLeftParen		ifTrue: 			[self step.			^self locate: CobolToken leftParen].	self isRightParen		ifTrue: 			[self step.			^self locate: CobolToken rightParen].	self isPlus		ifTrue: 			[self step.			^self locate: CobolToken plus].	self isEqual		ifTrue: 			[self step.			^self locate: CobolToken equal].	"Colon or :: (reference modification separator)."	self isColon		ifTrue: 			[self step.			self isColon				ifTrue: 					[self step.					^self locate: CobolToken doubleColon].			^self locate: CobolToken colon].	"Minus: operator (not part of an identifier here — identifiers start alpha)."	self isMinus		ifTrue: 			[self step.			^self locate: CobolToken minus].	"Asterisk or ** (exponentiation)."	self isAsterisk		ifTrue: 			[self step.			self isPeekAsterisk				ifTrue: 					[self step.					^self locate: CobolToken exponent].			^self locate: CobolToken asterisk].	"Slash."	self isSlash		ifTrue: 			[self step.			^self locate: CobolToken slash].	"Relational operators: &gt; &gt;= &lt; &lt;= &lt;&gt;."	self isGreater		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken greaterEqual].			^self locate: CobolToken greater].	self isLess		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken lessEqual].			self isPeekGreater				ifTrue: 					[self step.					^self locate: CobolToken notEqual].			^self locate: CobolToken less].	"Numeric literal (leading digit)."	self isDigit ifTrue: [^self scanForNumber].	"String literals."	self isDoubleQuote ifTrue: [^self scanForString].	self isSingleQuote ifTrue: [^self scanForSingleQuotedString].	"Identifier or keyword (must start with a letter)."	currentCharacter isLetter ifTrue: [^self scanForIdentifier].	"Picture starting with $"	self isDollar ifTrue: [^self scanForPic].	^self locate: (CobolToken error: istream)</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForIdentifier">scanForIdentifier	"Scan an identifier or COBOL keyword.	 Identifiers may contain letters, digits, and embedded hyphens,	 but may not begin or end with a hyphen."	| identifier upper |	identifier := ''.	[ self isIdentifierCharacter ] whileTrue: [		identifier := identifier , currentCharacter asString.		self step ].	"Strip trailing hyphens (not valid in COBOL identifiers)."	[ identifier notEmpty and: [ identifier last = $- ] ] whileTrue: [		identifier := identifier copyFrom: 1 to: identifier size - 1 ].	upper := identifier asUppercase.	(self isKeyword: upper)		ifTrue: [ ^ self locate:(CobolToken keyword: upper) ]		ifFalse: [ ^ self locate:(CobolToken identifier: identifier) ]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForIdentifier">scanForIdentifier	"Scan an identifier or COBOL keyword.	 Identifiers may contain letters, digits, and embedded hyphens,	 but may not begin or end with a hyphen."	| identifier upper |	identifier := ''.	[self isIdentifierCharacter] whileTrue: 			[identifier := identifier , currentCharacter asString.			self step].	"Strip trailing hyphens (not valid in COBOL identifiers)."	[identifier notEmpty and: [identifier last = $-]]		whileTrue: [identifier := identifier copyFrom: 1 to: identifier size - 1].	upper := identifier asUppercase.	(self isKeyword: upper)		ifTrue: [^self locate: (CobolToken keyword: upper)]		ifFalse: [^self locate: (CobolToken identifier: identifier)]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForNumber">scanForNumber	"Scan an integer or decimal numeric literal."	| num |	num := ''.	[ self isDigit ] whileTrue: [		num := num , currentCharacter asString.		self step ].	"Decimal point followed by a digit — decimal literal."	(self isPeriod and: [ self isPeekDigit ]) ifTrue: [		num := num , '.'.		self step.		[ self isDigit ] whileTrue: [			num := num , currentCharacter asString.			self step ] ].	(num includesSubstring: '.')		ifTrue: [ ^ CobolToken decimal: num ]		ifFalse: [ ^ CobolToken integer: num ]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForNumber">scanForNumber	"Scan an integer or decimal numeric literal."	| num |	num := ''.	[self isDigit] whileTrue: 			[num := num , currentCharacter asString.			self step].	"Decimal point followed by a digit — decimal literal."	(self isPeriod and: [self isPeekDigit])		ifTrue: 			[num := num , '.'.			self step.			[self isDigit] whileTrue: 					[num := num , currentCharacter asString.					self step]].	(num includesSubstring: '.')		ifTrue: [^CobolToken decimal: num]		ifFalse: [^CobolToken integer: num]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForString">scanForString	"Scan a double-quoted string literal."	| str |	self step. "consume opening double-quote"	str := ''.	[ self isEof not and: [ self isStringCharacter ] ] whileTrue: [		str := str , currentCharacter asString.		self step ].	self isEof ifFalse: [ self step ]. "consume closing double-quote"	^ CobolToken string: str</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForString">scanForString	"Scan a double-quoted string literal."	| str |	self step.	"consume opening double-quote"	str := ''.	[self isEof not and: [self isStringCharacter]] whileTrue: 			[str := str , currentCharacter asString.			self step].	self isEof ifFalse: [self step].	"consume closing double-quote"	^CobolToken string: str</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForSingleQuotedString">scanForSingleQuotedString	"Scan a single-quoted string literal."	| str |	self step. "consume opening single-quote"	str := ''.	[ self isEof not and: [ self isSingleQuotedStringCharacter ] ]		whileTrue: [			str := str , currentCharacter asString.			self step ].	self isEof ifFalse: [ self step ]. "consume closing single-quote"	^ CobolToken string: str</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForSingleQuotedString">scanForSingleQuotedString	"Scan a single-quoted string literal."	| str |	self step.	"consume opening single-quote"	str := ''.	[self isEof not and: [self isSingleQuotedStringCharacter]] whileTrue: 			[str := str , currentCharacter asString.			self step].	self isEof ifFalse: [self step].	"consume closing single-quote"	^CobolToken string: str</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="skipToEndOfLine">skipToEndOfLine	"Consume characters up to and including the next line feed."	[ self isEof not and: [ currentCharacter = Character lf ] ]		whileFalse: [ self step ].	self isEof ifFalse: [ self step ]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="skipToEndOfLine">skipToEndOfLine	"Consume characters up to and including the next line feed."	[self isEof not and: [currentCharacter = Character lf]]		whileFalse: [self step].	self isEof ifFalse: [self step]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="skipWhitespace">skipWhitespace	[ self isWhitespace ] whileTrue: [		self step.		self isCommentLine ifTrue: [ self skipToEndOfLine ] ]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="skipWhitespace">skipWhitespace	[self isWhitespace] whileTrue: 			[self step.			self isCommentLine ifTrue: [self skipToEndOfLine]]</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForPic">scanForPic	"Scan a picture clause up to eof or period."	| more str |	str := ''.	more := true.	[ more ] whileTrue: [		str := str , currentCharacter asString.		self isEof ifTrue: [ more := false ].		(self isPeriod and: [ self isPeekDigit not ])			ifTrue: [ more := false ]			ifFalse: [ self step ] ].	self isPeriod ifTrue: [ self step ].	^ CobolToken pic: str</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForPic">scanForPic	"Scan a picture clause up to eof or period."	| more str |	str := ''.	more := true.	[more] whileTrue: 			[str := str , currentCharacter asString.			self isEof ifTrue: [more := false].			(self isPeriod and: [self isPeekDigit not])				ifTrue: [more := false]				ifFalse: [self step]].	self isPeriod ifTrue: [self step].	^CobolToken pic: str</body></methods><do-it>CobolScanner organization addCategory: #'keyword table'</do-it><methods><class-id>CobolScanner</class-id> <category>keyword table</category><body package="CobolStudio" selector="isKeyword:">isKeyword: anUppercaseString	^ self class keywords includes: anUppercaseString</body></methods><methods><class-id>CobolScanner</class-id> <category>keyword table</category><body package="CobolStudio" selector="isKeyword:">isKeyword: anUppercaseString	^self class keywords includes: anUppercaseString</body></methods><methods><class-id>CobolScanner class</class-id> <category>instance creation</category><body package="CobolStudio" selector="on:">on: aString	^ self new on: aString readStream</body></methods><methods><class-id>CobolScanner class</class-id> <category>instance creation</category><body package="CobolStudio" selector="on:">on: aString	^self new on: aString readStream</body></methods><do-it>CobolScanner class organization addCategory: #keywords</do-it><methods><class-id>CobolScanner class</class-id> <category>keywords</category><body package="CobolStudio" selector="keywords">keywords	"Return the set of all standard COBOL reserved words (uppercased).	 Based on COBOL 2014 / IBM Enterprise COBOL reserved word list."	^ #( 'ACCEPT' 'ACCESS' 'ADD' 'ADDRESS' 'ADVANCING' 'AFTER' 'ALL'	     'ALPHABET' 'ALPHABETIC' 'ALPHABETIC-LOWER' 'ALPHABETIC-UPPER'	     'ALPHANUMERIC' 'ALPHANUMERIC-EDITED' 'ALSO' 'ALTER' 'ALTERNATE'	     'AND' 'ANY' 'APPLY' 'ARE' 'AREA' 'AREAS' 'ASCENDING' 'ASSIGN'	     'AT' 'AUTHOR' 'BASIS' 'BEFORE' 'BEGINNING' 'BINARY' 'BLANK'	     'BLOCK' 'BOTTOM' 'BY' 'CALL' 'CANCEL' 'CBL' 'CHARACTER'	     'CHARACTERS' 'CLASS' 'CLOCK-UNITS' 'CLOSE' 'COBO