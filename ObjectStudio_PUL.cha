-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="column">column	^column</body></methods><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="column:">column: anObject	column := anObject</body></methods><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="row">row	^row</body></methods><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="row:">row: anObject	row := anObject</body></methods><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="type">type	^type</body></methods><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="type:">type: anObject	type := anObject</body></methods><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="value">value	^value</body></methods><methods><class-id>CobolToken</class-id> <category>accessing</category><body package="CobolStudio" selector="value:">value: anObject	value := anObject</body></methods><comment><class-id>CobolToken</class-id><body>CobolToken has not been commented.  The comment should state the purpose of the class and also explain any unobvious aspects of the implementation.Instance Variables:	column	&lt;Object&gt;	column in source code	row		&lt;Object&gt;	row in source code	type		&lt;Object&gt;	token classification	value	&lt;Object&gt;	string value</body></comment><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 6, 2026' '11:21:11 PM')""An image file C:\Pr