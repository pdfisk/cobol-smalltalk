r or: [aCharacter asInteger = 9	"tab"]]]</body></methods><methods><class-id>CobolScanner</class-id> <category>initialize-release</category><body package="CobolStudio" selector="on:">on: aStream	istream := aStream.	self column: 0.	self row: 1.	self step.	^self</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '3:38:04 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 3:38:04 PM on April 7, 2026."</do-it><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '3:38:37 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 3:38:37 PM on April 7, 2026."</do-it><methods><class-id>CobolFile class</class-id> <category>accessing</category><body package="CobolStudio" selector="listFiles">listFiles	"List all files and directories in a directory"	| dir |	dir := Filename named: self dirPath.	^dir contents</body></methods><methods><class-id>CobolFile class</class-id> <category>accessing</category><body package="CobolStudio" selector="listFiles">listFiles	"List all files and directories in a directory"	| dir |	dir := Filename named: self dirPath.	^dir </body></methods><methods><class-id>CobolFile class</class-id> <category>accessing</category><body package="CobolStudio" selector="listFiles">listFiles	"List all files and directories in a directory"	| dir |	dir := Filename named: self dirPath.	^dir directoryContents</body></methods><methods><class-id>CobolWorkbench class</class-id> <category>examples</category><body package="CobolStudio" selector="allTokens">allTokens	"CobolWorkbench allTokens"	| collection files scanner |	collection := OrderedCollection new.	files := CobolFile listFiles.	files do: 			[:file |			scanner := CobolScanner on: (CobolFile readFile: file).			collection addAll: scanner allTokens].	^collection</body></methods><methods><class-id>CobolWorkbench class</class-id> <category>examples</category><body package="CobolStudio" selector="allTokens">allTokens	"CobolWorkbench allTokens inspect"	| collection files scanner |	collection := OrderedCollection new.	files := CobolFile listFiles.	files do: 			[:file |			scanner := CobolScanner on: (CobolFile readFile: file).			collection addAll: scanner allTokens].	^collection</body></methods><methods><class-id>CobolToken class</class-id> <category>types</category><body package="CobolStudio" selector="decimalType">decimalType	^#decimal</body></methods><methods><class-id>CobolToken class</class-id> <category>creation</category><body package="CobolStudio" selector="decimal:">decimal: aValue	^self type: self decimalType value: aValue asDecimal</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForNumber">scanForNumber	"Scan an integer or decimal numeric literal."	| num |	num := ''.	[self isDigit] whileTrue: 			[num := num , currentCharacter asString.			self step].	"Decimal point followed by a digit — decimal literal."	(self isPeriod and: [self isPeekDigit])		ifTrue: 			[num := num , '.'.			self step.			[self isDigit] whileTrue: 					[num := num , currentCharacter asString.					self step]].	(num includes: '.')		ifTrue: [^CobolToken decimal: num]		ifFalse: [^CobolToken integer: num]</body></methods><methods><class-id>CobolFile class</class-id> <category>accessing</category><body package="CobolStudio" selector="listFiles">listFiles|  dir  |dir := Filename named: self dirPath.dir browse</body></methods><methods><class-id>CobolFile class</class-id> <category>accessing</category><body package="CobolStudio" selector="listFiles">listFiles	| dir |	dir := Filename named: self dirPath.	dir browse</body></methods><methods><class-id>CobolFile class</class-id> <category>accessing</category><body package="CobolStudio" selector="listFiles">listFiles	| dir |	dir := Filename named: self dirPath.	^ dir directoryContents</body></methods><methods><class-id>CobolFile class</class-id> <category>accessing</category><body package="CobolStudio" selector="listFiles">listFiles	| dir |	dir := Filename named: self dirPath.	^dir directoryContents</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '5:30:11 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 5:30:11 PM on April 7, 2026."</do-it><methods><class-id>CobolWorkbench class</class-id> <category>examples</category><body package="CobolStudio" selector="allTokens">allTokens	"CobolWorkbench hello"	| collection files scanner |	collection := OrderedCollection new.	files := CobolFile listFiles.	files do: 			[:file |			scanner := CobolScanner on: (CobolFile readFile: file).			collection addAll: scanner allTokens].	^collection</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '5:33:25 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 5:33:25 PM on April 7, 2026."</do-it><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="scanForNumber">scanForNumber	"Scan an integer or decimal numeric literal."	| num |	num := ''.	[self isDigit] whileTrue: 			[num := num , currentCharacter asString.			self step].	"Decimal point followed by a digit — decimal literal."	(self isPeriod and: [self isPeekDigit])		ifTrue: 			[num := num , '.'.			self step.			[self isDigit] whileTrue: 					[num := num , currentCharacter asString.					self step]].	(num includes: '.')		ifTrue: [^CobolToken decimal: num]		ifFalse: [^CobolToken integer: num]</body></methods><methods><class-id>CobolToken class</class-id> <category>types</category><body package="CobolStudio" selector="decimalType">decimalType	^ #decimal</body></methods><methods><class-id>CobolToken class</class-id> <category>types</category><body package="CobolStudio" selector="decimalType">decimalType	^#decimal</body></methods><methods><class-id>CobolToken class</class-id> <category>creation</category><body package="CobolStudio" selector="decimal:">decimal: aValue	^self type: self decimalType value: aValue asDecimal</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '5:37:32 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 5:37:32 PM on April 7, 2026."</do-it><methods><class-id>CobolWorkbench class</class-id> <category>examples</category><body package="CobolStudio" selector="allTokens">allTokens	"CobolWorkbench hello"	| collection files scanner |	collection := OrderedCollection new.	files := CobolFile listFiles.	files do: 			[:file |			scanner := CobolScanner on: (CobolFile readFile: file).			collection add: scanner allTokens].	^collection</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '5:42:02 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 5:42:02 PM on April 7, 2026."</do-it><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '5:44:38 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 5:44:38 PM on April 7, 2026."</do-it><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '5:46:11 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.