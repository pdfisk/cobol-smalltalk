ty><name>HTTP</name> <type>bundle</type><property>comment</property> <value>'HTTP support provides the ability to make connections to servers in order to request resources via the HTTP protocol. Implemented specifications:RFC7231: HTTP Semantics and ContentRFC7230: HTTP/1.1RFC7540: HTTP/2RFC7541: HPACK Header Compression for HTTP/2RFC6265: CookiesRFC6266: Content-DispositionRFC2818: HTTP Over TLSRFC7616: HTTP Digest Access AuthenticationRFC7617: HTTP Basic AuthenticationRFC7235: Hypertext Transfer Protocol (HTTP/1.1): AuthenticationExamples:	"Use Http/1.1 protocol"	(HttpClient get: ''https://www.google.com/'') inspect.	"Use Http/2 protocol"	client := HttpClient new.	client useH2.	(client get: ''https://www.google.com/'') inspect.	client close.'</value></component-property><component-property><name>HTTP</name> <type>bundle</type><property>notice</property> <value>'Copyright 1999-2022 Cincom Systems, Inc.  All rights reserved.'</value></component-property><component-property><name>HTTP</name> <type>bundle</type><property>prerequisiteDescriptions</property> <value>#(#(#name 'MIME' #componentType #package) #(#name 'Protocols-Http' #componentType #package) #(#name 'URISupport' #componentType #package) #(#name 'Xtreams-Terminals' #componentType #package) #(#name 'Protocols-Http2' #componentType #package) #(#name 'Protocols-Logger' #componentType #package))</value></component-property><component-property><name>HTTP</name> <type>bundle</type><property>developmentPrerequisites</property> <value>#(#(#any 'MIME' '') #(#any 'Protocols-Http' '') #(#any 'URISupport' '') #(#any 'Xtreams-Terminals' '') #(#any 'Protocols-Http2' '') #(#any 'Protocols-Logger' ''))</value></component-property><component-property><name>HTTP</name> <type>bundle</type><property>prerequisiteParcels</property> <value>#(#('MIME' '') #('Protocols-Http' '') #('URISupport' '') #('Xtreams-Terminals' '') #('Protocols-Http2' '') #('Protocols-Logger' ''))</value></component-property><component-created><name>HTTP-Exceptions</name> <type>package</type></component-created><component-property><name>HTTP-Exceptions</name> <type>package</type><property>notice</property> <value>'Copyright 1999-2020 Cincom Systems, Inc.  All rights reserved.'</value></component-property><component-property><name>HTTP-Exceptions</name> <type>package</type><property>isFunctional</property> <value>false</value></component-property><component-property><name>HTTP-Exceptions</name> <type>package</type><property>comment</property> <value>'HTTP exception classes'</value></component-property><component-created><name>HTTP-Headers</name> <type>package</type></component-created><component-property><name>HTTP-Headers</name> <type>package</type><property>notice</property> <value>'Copyright 1999-2020 Cincom Systems, Inc.  All rights reserved.'</value></component-property><component-property><name>HTTP-Headers</name> <type>package</type><property>isFunctional</property> <value>false</value></component-property><component-property><name>HTTP-Headers</name> <type>package</type><property>comment</property> <value>'HTTP header fields'</value></component-property><component-created><name>HTTP-Support</name> <type>package</type></component-created><component-property><name>HTTP-Support</name> <type>package</type><property>notice</property> <value>'Copyright 1999-2021 Cincom Systems, Inc.  All rights reserved.'</value></component-property><component-property><name>HTTP-Support</name> <type>package</type><property>isFunctional</property> <value>false</value></component-property><component-property><name>HTTP-Support</name> <type>package</type><property>comment</property> <value>'HTTP support classes'</value></component-property><component-created><name>HTTP</name> <type>package</type></component-created><component-property><name>HTTP</name> <type>package</type><property>parcelName</property> <value>'HTTP'</value></component-property><component-property><name>HTTP</name> <type>package</type><property>isFunctional</property> <value>false</value></component-property><component-property><name>HTTP</name> <type>package</type><property>notice</property> <value>'Copyright 1999-2022 Cincom Systems, Inc.  All rights reserved.'</value></component-property><component-property><name>HTTP</name> <type>package</type><property>comment</property> <value>'HTTP support provides the ability to make connections to servers in order to request resources via the HTTP protocol, which is a superset of MIME.'</value></component-property><component-created><name>HTTP2</name> <type>package</type></component-created><component-property><name>HTTP2</name> <type>package</type><property>disregardedPrerequisites</property> <value>#(#(#name 'MIME' #componentType #package) #(#name 'NetClientBase' #componentType #package) #(#name 'Protocols-Common' #componentType #package) #(#name 'Protocols-Http' #componentType #package))</value></component-property><component-property><name>HTTP2</name> <type>package</type><property>isFunctional</property> <value>false</value></component-property><component-property><name>HTTP2</name> <type>package</type><property>comment</property> <value>'Implements HTTP/2 protocol. Examples:1.	client := Net.HttpClient new.	client useH2.  "Instructs the client to upgrade to HTTP/2 protocol. "	response1 := client get:  ''https://www.google.com/'' .	response2 := client get:  ''https://www.google.com/maps''.	client close.2.	urls := #(	''https://www.google.com/maps''	''https://www.google.com/maps/search/Groceries/''	''https://www.google.com/maps/search/Food+Delivery/''	''https://www.google.com/maps/search/Takeout/''	''https://www.google.com/maps/search/Hotels/''	).		client := HttpClient new.	client 		useH2;		useSecureConnection;		hostName: ''www.google.com'';		connect.		1 to: urls size do: [ :i |		client execute: ( Net.HttpRequest get: (urls at: i )).	].		responses := OrderedCollection new.	urls size timesRepeat: [ responses add: client readResponse].		responses inspect.	client close.'</value></component-property><component-property><name>HTTP2</name> <type>package</type><property>notice</property> <value>'Copyright 1999-2022 Cincom Systems, Inc.  All rights reserved.'</value></component-property><component-property><name>HTTP2</name> <type>package</type><property>prerequisiteDescriptions</property> <value>#(#(#name 'Protocols-Http2' #componentType #package) #(#name 'Xtreams-Core' #componentType #package) #(#name 'HTTP' #componentType #bundle))</value></component-property><component-property><name>HTTP2</name> <type>package</type><property>developmentPrerequisites</property> <value>#(#(#any 'Protocols-Http2' '') #(#any 'Xtreams-Core' '') #(#any 'HTTP' ''))</value></component-property><component-property><name>HTTP2</name> <type>package</type><property>prerequisiteParcels</property> <value>#(#('Protocols-Http2' '') #('Xtreams-Core' '') #('HTTP' ''))</value></component-property><parcel-loaded><name>HTTP</name> <filename>(OS.PortableFilename fromComponents: #('$(VISUALWORKS)' 'net' 'HTTP.pcl'))</filename></parcel-loaded><component-created><name>Help-Model</name> <type>package</type></component-created><parcel-loaded><name>Help-Model</name> <filename>(OS.PortableFilename fromComponents: #('$(VISUALWORKS)' 'parcels' 'Help-Model.pcl'))</filename></parcel-loaded><component-created><name>Help-UI</name> <type>package</type></component-created><parcel-loaded><name>Help-UI</name> <filename>(OS.PortableFilename fromComponents: #('$(VISUALWORKS)' 'parcels' 'Help-UI.pcl'))</filename></parcel-loaded><component-created><name>ODBCThapiEXDI</name> <type>package</type></component-created><parcel-loaded><name>ODBCThapiEXDI</name> <filename>(OS.PortableFilename fromComponents: #('$(VISUALWORKS)' 'database' 'ODBCThapiEXDI.pcl'))</filename></parcel-loaded