			self isPeekAsterisk				ifTrue: 					[self step.					^self locate: CobolToken exponent].			^self locate: CobolToken asterisk].	"Slash."	self isSlash		ifTrue: 			[self step.			^self locate: CobolToken slash].	"Relational operators: &gt; &gt;= &lt; &lt;= &lt;&gt;."	self isGreater		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken greaterEqual].			^self locate: CobolToken greater].	self isLess		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken lessEqual].			self isPeekGreater				ifTrue: 					[self step.					^self locate: CobolToken notEqual].			^self locate: CobolToken less].	"Numeric literal (leading digit)."	self isDigit ifTrue: [^self scanForNumber].	"String literals."	self isDoubleQuote ifTrue: [^self scanForString].	self isSingleQuote ifTrue: [^self scanForSingleQuotedString].	"Identifier or keyword (must start with a letter)."	currentCharacter isLetter ifTrue: [^self scanForIdentifier].	"Picture starting with $"	self isDollar ifTrue: [^self scanForPic].	^self locate: (CobolToken error: istream)</body></methods><methods><class-id>CobolToken class</class-id> <category>creation</category><body package="CobolStudio" selector="less">less	^self type: self lessType</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '1:32:42 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 1:32:42 AM on April 8, 2026."</do-it><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">stepself row &gt; 90 ifTrue:[('STEPPING: ', self row asString) out].	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	self row &gt; 90 ifTrue: [('STEPPING: ' , self row asString) out].	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	self row &gt; 90 ifTrue: [		('STEPPING: ' , self row asString) out		].	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '1:37:07 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 1:37:07 AM on April 8, 2026."</do-it><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '1:37:43 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 1:37:43 AM on April 8, 2026."</do-it><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	self row &gt;= 97 ifTrue: [		('STEPPING: ' , self row asString) out		].	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	self row &gt;= 97 ifTrue: [('STEPPING: ' , self row asString) out].	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	self row &gt;= 97 ifTrue: [		('STEPPING: ' , self row asString) out		].	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="nextToken">nextToken	"Return the next token from the input stream."	self row &gt; 90 ifTrue: [		('STEPPING: ' , self row asString) out		].	self isEof ifTrue: [^self locate: CobolToken eof].	self skipWhitespace.	self isEof ifTrue: [^self locate: CobolToken eof].	row &gt;= 95 ifTrue: ['check' out].	"Inline comment *&gt; — skip to end of line."	self isInlineCommentStart		ifTrue: 			[self skipToEndOfLine.			^self nextToken].	"Single-character punctuation."	self isPeriod		ifTrue: 			[self step.			^self locate: CobolToken period].	self isComma		ifTrue: 			[self step.			^self locate: CobolToken comma].	self isSemicolon		ifTrue: 			[self step.			^self locate: CobolToken semicolon].	self isLeftParen		ifTrue: 			[self step.			^self locate: CobolToken leftParen].	self isRightParen		ifTrue: 			[self step.			^self locate: CobolToken rightParen].	self isPlus		ifTrue: 			[self step.			^self locate: CobolToken plus].	self isEqual		ifTrue: 			[self step.			^self locate: CobolToken equal].	"Colon or :: (reference modification separator)."	self isColon		ifTrue: 			[self step.			self isColon				ifTrue: 					[self step.					^self locate: CobolToken doubleColon].			^self locate: CobolToken colon].	"Minus: operator (not part of an identifier here — identifiers start alpha)."	self isMinus		ifTrue: 			[self step.			^self locate: CobolToken minus].	"Asterisk or ** (exponentiation)."	self isAsterisk		ifTrue: 			[self step.			self isPeekAsterisk				ifTrue: 					[self step.					^self locate: CobolToken exponent].			^self locate: CobolToken asterisk].	"Slash."	self isSlash		ifTrue: 			[self step.			^self locate: CobolToken slash].	"Relational operators: &gt; &gt;= &lt; &lt;= &lt;&gt;."	self isGreater		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken greaterEqual].			^self locate: CobolToken greater].	self isLess		ifTrue: 			[self step.			self isPeekEqual				ifTrue: 					[self step.					^self locate: CobolToken lessEqual].			self isPeekGreater				ifTrue: 					[self step.					^self locate: CobolToken notEqual].			^self locate: CobolToken less].	"Numeric literal (leading digit)."	self isDigit ifTrue: [^self scanForNumber].	"String literals."	self isDoubleQuote ifTrue: [^self scanForString].	self isSingleQuote ifTrue: [^self scanForSingleQuotedString].	"Identifier or keyword (must start with a letter)."	currentCharacter isLetter ifTrue: [^self scanForIdentifier].	"Picture starting with $"	self isDollar ifTrue: [^self scanForPic].	^self locate: (CobolToken error: istream)</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '1:52:04 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 1:52:04 AM on April 8, 2026."</do-it><methods><class-id>CobolScanner</class-id> <category>scanning</category><body package="CobolStudio" selector="nextToken">nextToken	"Return the next token from the input stream."	self row &gt;= 97 ifTrue: [		('STEPPING: ' , self row asString) out		].	self isEof ifTrue: [^self locate: CobolToken eof].	self skipWhitespace.	self isEof ifTrue: [^self locate: CobolToken eof].	row &gt;= 95 ifTrue: ['check' out].	"Inline comment *&gt; — skip to end of line."	self isInlineCommentStart		ifTrue: 			[self skipToEndOfLine.			^self nextToken].	"Single-character punctuation."	self isPeriod		ifTrue: 			[self step.			^self locate: CobolToken period].	self isComma		ifTrue: 			[self step.			^self locate: CobolToken comma].	self isSemicolon		ifTrue: 			[self step.			^self locate: CobolToken semicolon].	self isLeftParen		ifTrue: 			[self step.			^self locate: CobolToken leftParen].	self isRightParen		ifTrue: 			[self step.			^self locate: CobolToken rightParen].	self isPlus		ifTrue: 			[self step.			^self locate: CobolToken plus].	self isEqual		ifTrue: 			[self step.			^self locate: CobolToken equal].	"Colon or :: (reference modification separator)."	self isColon		ifTrue: 			[self step.			self isColon				ifTrue: 					[self step.					^self locate: CobolToken doubleColon].			^self locate: CobolToken colon].	"Minus: operator (not part of an identifier here — identifiers start alpha)."	self isMinus		ifTrue: 			[self step.			^self locate: CobolToken minus].	"Asterisk or ** (exponentiation)."	self isAsterisk		ifTrue: 			[self step.			self isPeekAsterisk	