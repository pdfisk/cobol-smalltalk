OBOL syntax including:  - Keywords (all standard COBOL reserved words)  - Identifiers (alphanumeric with embedded hyphens)  - Integer and decimal numeric literals  - String literals (single-quoted and double-quoted)  - Arithmetic operators: + - * / **  - Relational operators: = &gt; &lt; &gt;= &lt;= &lt;&gt;  - Punctuation: . , ; : ( )  - Inline comments (*&gt; ... to end of line)  - Fixed-format comment lines (* or / in column 7)  - EOF and error tokens</body></comment><comment><class-id>CobolScanner</class-id><body>Tokenize Cobol source code into a stream of typed tokens.Handles the full COBOL syntax including:  - Keywords (all standard COBOL reserved words)  - Identifiers (alphanumeric with embedded hyphens)  - Integer and decimal numeric literals  - String literals (single-quoted and double-quoted)  - Arithmetic operators: + - * / **  - Relational operators: = &gt; &lt; &gt;= &lt;= &lt;&gt;  - Punctuation: . , ; : ( )  - Inline comments (*&gt; ... to end of line)  - Fixed-format comment lines (* or / in column 7)  - EOF and error tokensInstance Variables:	column			&lt;Object&gt;	column in source code	row				&lt;Object&gt;	row in source code	istream			&lt;Object&gt;	input stream	currentCharacter	&lt;Object&gt;	a character</body></comment><do-it>CobolScanner organization addCategory: #'initialize-release'</do-it><methods><class-id>CobolScanner</class-id> <category>initialize-release</category><body package="CobolStudio" selector="on:">on: aStream	istream := aStream.	self column: 0.	self row: 0.</body></methods><do-it>CobolScanner organization addCategory: #private</do-it><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	istream atEnd		ifTrue: [ ^ nil ]		ifFalse: [			currentCharacter := istream next.			self isEndOfLine				ifTrue: [					self column: 0.					self row: self row + 1 ]				ifFalse: [ self column: self column + 1 ].			^ currentCharacter ]</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="isEndOfLine">isEndOfLine	^ currentCharacter = Character lf</body></methods><do-it>CobolScanner organization addCategory: #testing</do-it><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isCommentLine">isCommentLine	^ currentCharacter = $* and: [ column = 7 ]</body></methods><methods><class-id>CobolScanner</class-id> <category>accessing</category><body package="CobolStudio" selector="locate:">locate: aToken	aToken		column: self column;		row: self row.	^ aToken</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isWhitespace">isWhitespace	^ self isWhitespace: currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isEof">isEof	^ istream atEnd </body></methods><methods><class-id>CobolScanner</class-id> <category>accessing</category><body package="CobolStudio" selector="allTokens">allTokens	| more token tokens |	more := true.	tokens := OrderedCollection new.	[ more ] whileTrue: [		token := self nextToken.		tokens add: token.		more := self isEof not and: [ token isError not ] ].	^ tokens </body></methods><methods><class-id>CobolScanner</class-id> <category>accessing</category><body package="CobolStudio" selector="peek">peek	^ istream peek</body></methods><methods><class-id>CobolScanner</class-id> <category>accessing</category><body package="CobolStudio" selector="peek">peek	^istream peek</body></methods><methods><class-id>CobolScanner</class-id> <category>accessing</category><body package="CobolStudio" selector="isPeriod">isPeriod	^ self isPeriod: currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isInteger">isInteger	^ self isInteger: currentCharacter </body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isInteger:">isInteger: aCharacter	^ aCharacter isInteger</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isStringCharacter">isStringCharacter	^ self isStringCharacter: currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isEndOfLine">isEndOfLine	^ currentCharacter = Character lf</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isWhitespace:">isWhitespace: aCharacter	^ aCharacter = Character space or: [		  aCharacter = Character lf or: [			  aCharacter = Character cr or: [ aCharacter asInteger = 9 "tab" ] ] ]</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isWhitespace:">isWhitespace: aCharacter	^aCharacter = Character space or: 			[aCharacter = Character lf				or: [aCharacter = Character cr or: [aCharacter asInteger = 9	"tab"]]]</body></methods><methods><class-id>CobolScanner</class-id> <category>accessing</category><body package="CobolStudio" selector="allTokens">allTokens	| more token tokens |	more := true.	tokens := OrderedCollection new.	[more] whileTrue: 			[token := self nextToken.			tokens add: token.			more := self isEof not and: [token isError not]].	^tokens</body></methods><methods><class-id>CobolScanner</class-id> <category>initialize-release</category><body package="CobolStudio" selector="on:">on: aStream	istream := aStream.	self column: 0.	self row: 0</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	istream atEnd		ifTrue: [^nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1].			^currentCharacter]</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isCommentLine">isCommentLine	^currentCharacter = $* and: [column = 7]</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isEndOfLine">isEndOfLine	^currentCharacter = Character lf</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isEof">isEof	^istream atEnd</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isInteger">isInteger	^self isInteger: currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isInteger:">isInteger: aCharacter	^aCharacter isInteger</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isStringCharacter">isStringCharacter	^self isStringCharacter: currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isWhitespace">isWhitespace	^self isWhitespace: currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isAlphaNumeric">isAlphaNumeric	^ self isAlphaNumeric: currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>testing</category><body package="CobolStudio" selector="isAlphaNumeric">isAlphaNu