					anEntry organization: #indexed.									self advance ]								ifFalse: [									self error:										'Expected SEQUENTIAL, RELATIVE, or INDEXED after ORGANIZATION IS' ] ] ] ].	"ACCESS MODE [IS] SEQUENTIAL | RANDOM | DYNAMIC"	(self currentIsKeyword: 'ACCESS') ifTrue: [		self advance.		(self currentIsKeyword: 'MODE') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		(self currentIsKeyword: 'SEQUENTIAL')			ifTrue: [				anEntry accessMode: #sequential.				self advance ]			ifFalse: [				(self currentIsKeyword: 'RANDOM')					ifTrue: [						anEntry accessMode: #random.						self advance ]					ifFalse: [						(self currentIsKeyword: 'DYNAMIC')							ifTrue: [								anEntry accessMode: #dynamic.								self advance ]							ifFalse: [								self error:									'Expected SEQUENTIAL, RANDOM, or DYNAMIC after ACCESS MODE IS' ] ] ].		^ self ].	"FILE STATUS [IS] data-name"	(self currentIsKeyword: 'FILE') ifTrue: [		self advance.		(self currentIsKeyword: 'STATUS') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		anEntry fileStatus: self consumeName.		^ self ].	"RECORD KEY [IS] data-name  –or–  RECORD DELIMITER [IS] ..."	(self currentIsKeyword: 'RECORD') ifTrue: [		self advance.		(self currentIsKeyword: 'KEY') ifTrue: [			self advance.			(self currentIsKeyword: 'IS') ifTrue: [ self advance ].			anEntry recordKey: self consumeName.			^ self ].		(self currentIsKeyword: 'DELIMITER') ifTrue: [			self advance.			(self currentIsKeyword: 'IS') ifTrue: [ self advance ].			anEntry recordDelimiter: self consumeName.			^ self ].		self error:			'Expected KEY or DELIMITER after RECORD in SELECT clause' ].	"ALTERNATE RECORD KEY [IS] data-name [WITH DUPLICATES]"	(self currentIsKeyword: 'ALTERNATE') ifTrue: [		| dups keyName |		self advance.		(self currentIsKeyword: 'RECORD') ifTrue: [ self advance ].		(self currentIsKeyword: 'KEY') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		keyName := self consumeName.		dups := false.		(self currentIsKeyword: 'WITH') ifTrue: [			self advance.			(self currentIsKeyword: 'DUPLICATES') ifTrue: [				dups := true.				self advance ] ].		(self currentIsKeyword: 'DUPLICATES') ifTrue: [			dups := true.			self advance ].		anEntry alternateRecordKeys add:			(CobolAlternateRecordKey dataName: keyName duplicates: dups).		^ self ].	"PADDING CHARACTER [IS] literal|data-name"	(self currentIsKeyword: 'PADDING') ifTrue: [		self advance.		(self currentIsKeyword: 'CHARACTER') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		anEntry paddingCharacter: currentToken value.		self advance.		^ self ].	"RESERVE integer AREA[S]  — parsed and discarded (informational only)"	(self currentIsKeyword: 'RESERVE') ifTrue: [		self advance.		(currentToken isInteger or: [ self currentIsKeyword: 'ALTERNATE' ])			ifTrue: [ self advance ].		((self currentIsKeyword: 'AREA') or: [			 self currentIsKeyword: 'AREAS' ]) ifTrue: [ self advance ].		^ self ].	"Unrecognised clause token — skip it."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSelectClause:">parseSelectClause: anEntry	"Parse one optional clause of a SELECT entry and store it in anEntry."	"ASSIGN TO ..."	(self currentIsKeyword: 'ASSIGN')		ifTrue: 			["ORGANIZATION [IS] [LINE] SEQUENTIAL | RELATIVE | INDEXED"			self advance.			(self currentIsKeyword: 'TO') ifTrue: [self advance].			"Collect one or more assignment targets."			[self currentIsName or: [currentToken isString]] whileTrue: 					[anEntry assignTo add: currentToken value.					self advance].			^self].	"ORGANIZATION [IS] [LINE] SEQUENTIAL | RELATIVE | INDEXED"	(self currentIsKeyword: 'ORGANIZATION')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			(self currentIsKeyword: 'LINE')				ifTrue: 					[self advance.					self consumeKeyword: 'SEQUENTIAL'.					anEntry organization: #lineSequential]]		ifFalse: 			[(self currentIsKeyword: 'SEQUENTIAL')				ifTrue: 					[anEntry organization: #sequential.					self advance]				ifFalse: 					[(self currentIsKeyword: 'RELATIVE')						ifTrue: 							[anEntry organization: #relative.							self advance]						ifFalse: 							[(self currentIsKeyword: 'INDEXED')								ifTrue: 									[anEntry organization: #indexed.									self advance]								ifFalse: 									[self										error: 'Expected SEQUENTIAL, RELATIVE, or INDEXED after ORGANIZATION IS']]]].	"ACCESS MODE [IS] SEQUENTIAL | RANDOM | DYNAMIC"	(self currentIsKeyword: 'ACCESS')		ifTrue: 			[self advance.			(self currentIsKeyword: 'MODE') ifTrue: [self advance].			(self currentIsKeyword: 'IS') ifTrue: [self advance].			(self currentIsKeyword: 'SEQUENTIAL')				ifTrue: 					[anEntry accessMode: #sequential.					self advance]				ifFalse: 					[(self currentIsKeyword: 'RANDOM')						ifTrue: 							[anEntry accessMode: #random.							self advance]						ifFalse: 							[(self currentIsKeyword: 'DYNAMIC')								ifTrue: 									[anEntry accessMode: #dynamic.									self advance]								ifFalse: 									[self error: 'Expected SEQUENTIAL, RANDOM, or DYNAMIC after ACCESS MODE IS']]].			^self].	"FILE STATUS [IS] data-name"	(self currentIsKeyword: 'FILE')		ifTrue: 			[self advance.			(self currentIsKeyword: 'STATUS') ifTrue: [self advance].			(self currentIsKeyword: 'IS') ifTrue: [self advance].			anEntry fileStatus: self consumeName.			^self].	"RECORD KEY [IS] data-name  –or–  RECORD DELIMITER [IS] ..."	(self currentIsKeyword: 'RECORD')		ifTrue: 			[self advance.			(self currentIsKeyword: 'KEY')				ifTrue: 					[self advance.					(self currentIsKeyword: 'IS') ifTrue: [self advance].					anEntry recordKey: self consumeName.					^self].			(self currentIsKeyword: 'DELIMITER')				ifTrue: 					[self advance.					(self currentIsKeyword: 'IS') ifTrue: [self advance].					anEntry recordDelimiter: self consumeName.					^self].			self error: 'Expected KEY or DELIMITER after RECORD in SELECT clause'].	"ALTERNATE RECORD KEY [IS] data-name [WITH DUPLICATES]"	(self currentIsKeyword: 'ALTERNATE')		ifTrue: 			[| dups keyName |			self advance.			(self currentIsKeyword: 'RECORD') ifTrue: [self advance].			(self currentIsKeyword: 'KEY') ifTrue: [self advance].			(self currentIsKeyword: 'IS') ifTrue: [self advance].			keyName := self consumeName.			dups := false.			(self currentIsKeyword: 'WITH')				ifTrue: 					[self advance.					(self currentIsKeyword: 'DUPLICATES')						ifTrue: 							[dups := true.							self advance]].			(self currentIsKeyword: 'DUPLICATES')				ifTrue: 					[dups := true.					self advance].			anEntry alternateRecordKeys				add: (CobolAlternateRecordKey dataName: keyName duplicates: dups).			^self].	"PADDING CHARACTER [IS] literal|data-name"	(self currentIsKeyword: 'PADDING')		ifTrue: 			[self advance.			(self currentIsKeyword: 'CHARACTER') ifTrue: [self advance].			(self currentIsKeyword: 'IS') ifTrue: [self advance].			anEntry paddingCharacter: currentToken value.			self advance.			^self].	"RESERVE integer AREA[S]  — parsed and discarded (informational only)"	(self currentIsKeyword: 'RESERVE')		ifTrue: 			[self advance.			(currentToken isInteger or: [self currentIsKeyword: 'ALTERNATE'])				ifTrue: [self advance].			((self currentIsKeyword: 'AREA') or: [self currentIsKeyword: 'AREAS'])				ifTrue: [self advance].			^self].	"Unrecognised clause token — skip it."	self advance</body></methods><class><name>CobolIoControlParagraph</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseIoControlParagraph">parseIoControlParagraph	"Parse: I-O-CONTROL .	          { SAME [RECORD|SORT|SORT-MERGE] AREA FOR file-name... . } *	          { MULTIPLE FILE TAPE CONTAINS file-name [POSITION integer]... . } *	 Returns a CobolIoControlParagraph."	| para |	para := CobolIoControlParagraph new.	self consumeKeyword: 'I-O-CONTROL'.	self consumePeriod.	[	((self currentIsEof or: [ self isDivisionHeader ]) or: [		 self isEnvironmentDivisionSectionHeader ]) whileFalse: [		(self currentIsKeyword: 'SAME') ifTrue: [			para sameAreaClauses add: self parseSameAreaClause ].		(self currentIsKeyword: 'MULTIPLE') ifTrue: [			para multipleFileClauses add: self parseMultipleFileClause ].		"Skip unrecognised tokens to avoid looping."		(((((self currentIsKeyword: 'SAME') or: [			    self currentIsKeyword: 'MULTIPLE' ]) or: [ self currentIsEof ])			  or: [ self isDivisionHeader ]) or: [			 self isEnvironmentDivisionSectionHeader ]) ifFalse: [			self advance ] ] ].	^ para</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseIoControlParagraph">parseIoControlParagraph	"Parse: I-O-CONTROL .	          { SAME [RECORD|SORT|SORT-MERGE] AREA FOR file-name... . } *	          { MULTIPLE FILE TAPE CONTAINS file-name [POSITION integer]... . } *	 Returns a CobolIoControlParagraph."	| para |	para := CobolIoControlParagraph new.	self consumeKeyword: 'I-O-CONTROL'.	self consumePeriod.	[((self currentIsEof or: [self isDivisionHeader])		or: [self isEnvironmentDivisionSectionHeader]) whileFalse: 				[(self currentIsKeyword: 'SAME')					ifTrue: [para sameAreaClauses add: self parseSameAreaClause].				(self currentIsKeyword: 'MULTIPLE')					ifTrue: [para multipleFileClauses add: self parseMultipleFileClause].				"Skip unrecognised tokens to avoid looping."				(((((self currentIsKeyword: 'SAME')					or: [self currentIsKeyword: 'MULTIPLE']) or: [self currentIsEof])					or: [self isDivisionHeader]) or: [self isEnvironmentDivisionSectionHeader])					ifFalse: [self advance]]].	^para</body></methods><class><name>CobolSameAreaClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSameAreaClause">parseSameAreaClause	"Parse: SAME [RECORD|SORT|SORT-MERGE] AREA FOR file-name ... .	 Returns a CobolSameAreaClause."	| clause |	clause := CobolSameAreaClause new.	self consumeKeyword: 'SAME'.	(self currentIsKeyword: 'RECORD')		ifTrue: [			clause areaType: #record.			self advance ]		ifFalse: [			(self currentIsKeyword: 'SORT-MERGE')				ifTrue: [					clause areaType: #sortMerge.					self advance ]				ifFalse: [					(self currentIsKeyword: 'SORT')						ifTrue: [							clause areaType: #sort.							self advance ]						ifFalse: [ clause areaType: #area ] ] ].	(self currentIsKeyword: 'AREA') ifTrue: [ self advance ].	(self currentIsKeyword: 'FOR') ifTrue: [ self advance ].	[	self currentIsPeriod or: [		self currentIsEof or: [ self currentIsKeyword: 'SAME' ] ] ]		whileFalse: [ clause fileNames add: self consumeName ].	self currentIsPeriod ifTrue: [ self advance ].	^ clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseSameAreaClause">parseSameAreaClause	"Parse: SAME [RECORD|SORT|SORT-MERGE] AREA FOR file-name ... .	 Returns a CobolSameAreaClause."	| clause |	clause := CobolSameAreaClause new.	self consumeKeyword: 'SAME'.	(self currentIsKeyword: 'RECORD')		ifTrue: 			[clause areaType: #record.			self advance]		ifFalse: 			[(self currentIsKeyword: 'SORT-MERGE')				ifTrue: 					[clause areaType: #sortMerge.					self advance]				ifFalse: 					[(self currentIsKeyword: 'SORT')						ifTrue: 							[clause areaType: #sort.							self advance]						ifFalse: [clause areaType: #area]]].	(self currentIsKeyword: 'AREA') ifTrue: [self advance].	(self currentIsKeyword: 'FOR') ifTrue: [self advance].		[self currentIsPeriod		or: [self currentIsEof or: [self currentIsKeyword: 'SAME']]]			whileFalse: [clause fileNames add: self consumeName].	self currentIsPeriod ifTrue: [self advance].	^clause</body></methods><class><name>CobolMultipleFileClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseMultipleFileClause">parseMultipleFileClause	"Parse: MULTIPLE FILE TAPE CONTAINS	          file-name [POSITION integer] ... .	 Returns a CobolMultipleFileClause."	| clause |	clause := CobolMultipleFileClause new.	self consumeKeyword: 'MULTIPLE'.	(self currentIsKeyword: 'FILE') ifTrue: [ self advance ].	(self currentIsKeyword: 'TAPE') ifTrue: [ self advance ].	(self currentIsKeyword: 'CONTAINS') ifTrue: [ self advance ].	[	self currentIsPeriod or: [		self currentIsEof or: [ self currentIsKeyword: 'MULTIPLE' ] ] ]		whileFalse: [			| name pos |			name := self consumeName.			pos := nil.			(self currentIsKeyword: 'POSITION') ifTrue: [				self advance.				pos := currentToken value.				self advance ].			clause filePositionPairs add: name -&gt; pos ].	self currentIsPeriod ifTrue: [ self advance ].	^ clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseMultipleFileClause">parseMultipleFileClause	"Parse: MULTIPLE FILE TAPE CONTAINS	          file-name [POSITION integer] ... .	 Returns a CobolMultipleFileClause."	| clause |	clause := CobolMultipleFileClause new.	self consumeKeyword: 'MULTIPLE'.	(self currentIsKeyword: 'FILE') ifTrue: [self advance].	(self currentIsKeyword: 'TAPE') ifTrue: [self advance].	(self currentIsKeyword: 'CONTAINS') ifTrue: [self advance].		[self currentIsPeriod		or: [self currentIsEof or: [self currentIsKeyword: 'MULTIPLE']]]			whileFalse: 				[| name pos |				name := self consumeName.				pos := nil.				(self currentIsKeyword: 'POSITION')					ifTrue: 						[self advance.						pos := currentToken value.						self advance].				clause filePositionPairs add: name -&gt; pos].	self currentIsPeriod ifTrue: [self advance].	^clause</body></methods><do-it>CobolParser organization addCategory: #testign</do-it><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isEnvironmentDivisionSectionHeader">isEnvironmentDivisionSectionHeader	"True when the current token starts a named section within the Environment Division."	^ (self currentIsKeyword: 'CONFIGURATION') or: [		  self currentIsKeyword: 'INPUT-OUTPUT' ]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isEnvironmentDivisionSectionHeader">isEnvironmentDivisionSectionHeader	"True when the current token starts a named section within the Environment Division."	^(self currentIsKeyword: 'CONFIGURATION')		or: [self currentIsKeyword: 'INPUT-OUTPUT']</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDivisionHeader">isDivisionHeader	"True when the current token begins a top-level COBOL division header."	^ (self currentIsKeyword: 'IDENTIFICATION') or: [		  (self currentIsKeyword: 'ID') or: [			  (self currentIsKeyword: 'ENVIRONMENT') or: [				  (self currentIsKeyword: 'DATA') or: [					  self currentIsKeyword: 'PROCEDURE' ] ] ] ]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDivisionHeader">isDivisionHeader	"True when the current token begins a top-level COBOL division header."	^(self currentIsKeyword: 'IDENTIFICATION') or: 			[(self currentIsKeyword: 'ID') or: 					[(self currentIsKeyword: 'ENVIRONMENT')						or: [(self currentIsKeyword: 'DATA') or: [self currentIsKeyword: 'PROCEDURE']]]]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isConfigurationSectionParagraphHeader">isConfigurationSectionParagraphHeader	^ (self currentIsKeyword: 'SOURCE-COMPUTER') or: [		  (self currentIsKeyword: 'OBJECT-COMPUTER') or: [			  self currentIsKeyword: 'SPECIAL-NAMES' ] ]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isConfigurationSectionParagraphHeader">isConfigurationSectionParagraphHeader	^(self currentIsKeyword: 'SOURCE-COMPUTER') or: 			[(self currentIsKeyword: 'OBJECT-COMPUTER')				or: [self currentIsKeyword: 'SPECIAL-NAMES']]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataDivisionSectionHeader">isDataDivisionSectionHeader	"True when the current token opens a named section inside the Data Division."	^ (self currentIsKeyword: 'FILE') or: [		  (self currentIsKeyword: 'WORKING-STORAGE') or: [			  (self currentIsKeyword: 'LOCAL-STORAGE') or: [				  (self currentIsKeyword: 'LINKAGE') or: [					  (self currentIsKeyword: 'COMMUNICATION') or: [						  (self currentIsKeyword: 'REPORT') or: [							  self currentIsKeyword: 'SCREEN' ] ] ] ] ] ]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataDivisionSectionHeader">isDataDivisionSectionHeader	"True when the current token opens a named section inside the Data Division."	^(self currentIsKeyword: 'FILE') or: 			[(self currentIsKeyword: 'WORKING-STORAGE') or: 					[(self currentIsKeyword: 'LOCAL-STORAGE') or: 							[(self currentIsKeyword: 'LINKAGE') or: 									[(self currentIsKeyword: 'COMMUNICATION')										or: [(self currentIsKeyword: 'REPORT') or: [self currentIsKeyword: 'SCREEN']]]]]]</body></methods><class><name>CobolFileSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolFileSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileSection">parseFileSection	"Parse: FILE SECTION . { fd-or-sd-entry } *	 Returns a CobolFileSection."	| section |	section := CobolFileSection new.	self consumeKeyword: 'FILE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	[ (self currentIsKeyword: 'FD') or: [ self currentIsKeyword: 'SD' ] ]		whileTrue: [		section fileDescriptions add: self parseFileDescriptionEntry ].	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileSection">parseFileSection	"Parse: FILE SECTION . { fd-or-sd-entry } *	 Returns a CobolFileSection."	| section |	section := CobolFileSection new.	self consumeKeyword: 'FILE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	[(self currentIsKeyword: 'FD') or: [self currentIsKeyword: 'SD']]		whileTrue: [section fileDescriptions add: self parseFileDescriptionEntry].	^section</body></methods><class><name>CobolFileDescriptionEntry</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileDescriptionEntry">parseFileDescriptionEntry	"Parse one FD or SD entry and its record descriptions.	 Returns a CobolFileDescriptionEntry.	 Grammar:	   fd-entry ::= (FD|SD) file-name clause* .	               record-description*	"	| entry |	entry := CobolFileDescriptionEntry new.	(self currentIsKeyword: 'FD')		ifTrue: [ entry fileType: #fd ]		ifFalse: [ entry fileType: #sd ].	self advance.	entry fileName: self consumeName.	"Parse FD/SD descriptor clauses up to the terminating period."	[	self currentIsPeriod or: [		self currentIsEof or: [			self isDataDivisionSectionHeader or: [ self isDivisionHeader ] ] ] ]		whileFalse: [ self parseFileDescriptionClause: entry ].	self currentIsPeriod ifTrue: [ self advance ].	"Record descriptions that belong to this FD/SD."	entry items: self parseDataItems.	^ entry</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileDescriptionEntry">parseFileDescriptionEntry	"Parse one FD or SD entry and its record descriptions.	 Returns a CobolFileDescriptionEntry.	 Grammar:	   fd-entry ::= (FD|SD) file-name clause* .	               record-description*	"	| entry |	entry := CobolFileDescriptionEntry new.	(self currentIsKeyword: 'FD')		ifTrue: [entry fileType: #fd]		ifFalse: [entry fileType: #sd].	self advance.	entry fileName: self consumeName.	"Parse FD/SD descriptor clauses up to the terminating period."		[self currentIsPeriod or: 			[self currentIsEof				or: [self isDataDivisionSectionHeader or: [self isDivisionHeader]]]]			whileFalse: [self parseFileDescriptionClause: entry].	self currentIsPeriod ifTrue: [self advance].	"Record descriptions that belong to this FD/SD."	entry items: self parseDataItems.	^entry</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileDescriptionClause:">parseFileDescriptionClause: anEntry	"Parse one optional clause of an FD or SD entry."	| mode |	"BLOCK CONTAINS [int-1 TO] int-2 (RECORDS|CHARACTERS)"	(self currentIsKeyword: 'BLOCK') ifTrue: [		self advance.		(self currentIsKeyword: 'CONTAINS') ifTrue: [ self advance ].		anEntry blockContainsMin: currentToken value.		self advance.		(self currentIsKeyword: 'TO')			ifTrue: [				self advance.				anEntry blockContainsMax: currentToken value.				self advance ]			ifFalse: [				anEntry blockContainsMax: anEntry blockContainsMin.				anEntry blockContainsMin: nil ].		(self currentIsKeyword: 'RECORDS')			ifTrue: [				anEntry blockContainsUnit: #records.				self advance ]			ifFalse: [				(self currentIsKeyword: 'CHARACTERS') ifTrue: [					anEntry blockContainsUnit: #characters.					self advance ] ].		^ self ].	"RECORD CONTAINS [int-1 TO] int-2 [CHARACTERS]"	(self currentIsKeyword: 'RECORD') ifTrue: [		self advance.		(self currentIsKeyword: 'CONTAINS') ifTrue: [ self advance ].		anEntry recordContainsMin: currentToken value.		self advance.		(self currentIsKeyword: 'TO')			ifTrue: [				self advance.				anEntry recordContainsMax: currentToken value.				self advance ]			ifFalse: [				anEntry recordContainsMax: anEntry recordContainsMin.				anEntry recordContainsMin: nil ].		(self currentIsKeyword: 'CHARACTERS') ifTrue: [ self advance ].		^ self ].	"LABEL (RECORD IS | RECORDS ARE) (STANDARD | OMITTED | data-name)"	(self currentIsKeyword: 'LABEL') ifTrue: [		self advance.		((self currentIsKeyword: 'RECORD') or: [			 self currentIsKeyword: 'RECORDS' ]) ifTrue: [ self advance ].		((self currentIsKeyword: 'IS') or: [ self currentIsKeyword: 'ARE' ])			ifTrue: [ self advance ].		(self currentIsKeyword: 'STANDARD')			ifTrue: [				anEntry labelRecords: #standard.				self advance ]			ifFalse: [				(self currentIsKeyword: 'OMITTED')					ifTrue: [						anEntry labelRecords: #omitted.						self advance ]					ifFalse: [ anEntry labelRecords: nil ] ].		^ self ].	"VALUE OF data-name IS (literal | data-name)"	(self currentIsKeyword: 'VALUE') ifTrue: [		self advance.		(self currentIsKeyword: 'OF') ifTrue: [ self advance ].		[		self currentIsName and: [			(self currentIsKeyword: 'BLOCK') not and: [				(self currentIsKeyword: 'RECORD') not and: [					(self currentIsKeyword: 'LABEL') not ] ] ] ] whileTrue: [			self advance. "data-name"			(self currentIsKeyword: 'IS') ifTrue: [ self advance ].			self advance "literal or data-name" ].		^ self ].	"DATA (RECORD IS | RECORDS ARE) data-name..."	(self currentIsKeyword: 'DATA') ifTrue: [		self advance.		((self currentIsKeyword: 'RECORD') or: [			 self currentIsKeyword: 'RECORDS' ]) ifTrue: [ self advance ].		((self currentIsKeyword: 'IS') or: [ self currentIsKeyword: 'ARE' ])			ifTrue: [ self advance ].		[		self currentIsName and: [			(self currentIsKeyword: 'BLOCK') not and: [				(self currentIsKeyword: 'RECORD') not and: [					(self currentIsKeyword: 'LABEL') not and: [						self isDivisionHeader not ] ] ] ] ] whileTrue: [			anEntry dataRecords add: self consumeName ].		^ self ].	"LINAGE IS (int | data-name) LINES [subclauses]"	(self currentIsKeyword: 'LINAGE') ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		anEntry linageLines: currentToken value.		self advance.		(self currentIsKeyword: 'LINES') ifTrue: [ self advance ].		(self currentIsKeyword: 'WITH') ifTrue: [			self advance.			(self currentIsKeyword: 'FOOTING') ifTrue: [ self advance ].			(self currentIsKeyword: 'AT') ifTrue: [ self advance ].			anEntry linageFooting: currentToken value.			self advance ].		(self currentIsKeyword: 'LINES') ifTrue: [			self advance.			(self currentIsKeyword: 'AT') ifTrue: [ self advance ].			(self currentIsKeyword: 'TOP') ifTrue: [				self advance.				anEntry linageTop: currentToken value.				self advance ] ].		(self currentIsKeyword: 'LINES') ifTrue: [			self advance.			(self currentIsKeyword: 'AT') ifTrue: [ self advance ].			(self currentIsKeyword: 'BOTTOM') ifTrue: [				self advance.				anEntry linageBottom: currentToken value.				self advance ] ].		^ self ].	"RECORDING MODE IS (F | V | U | S)"	(self currentIsKeyword: 'RECORDING') ifTrue: [		self advance.		(self currentIsKeyword: 'MODE') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		mode := currentToken value asUppercase.		anEntry recordingMode: mode asSymbol.		self advance.		^ self ].	"CODE-SET IS alphabet-name"	(self currentIsKeyword: 'CODE-SET') ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		anEntry codeSet: self consumeName.		^ self ].	"EXTERNAL"	(self currentIsKeyword: 'EXTERNAL') ifTrue: [		anEntry external: true.		self advance.		^ self ].	"GLOBAL"	(self currentIsKeyword: 'GLOBAL') ifTrue: [		anEntry global: true.		self advance.		^ self ].	"Unknown — skip to avoid looping."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileDescriptionClause:">parseFileDescriptionClause: anEntry	"Parse one optional clause of an FD or SD entry."	"BLOCK CONTAINS [int-1 TO] int-2 (RECORDS|CHARACTERS)"	| mode |	(self currentIsKeyword: 'BLOCK')		ifTrue: 			[self advance.			(self currentIsKeyword: 'CONTAINS') ifTrue: [self advance].			anEntry blockContainsMin: currentToken value.			self advance.			(self currentIsKeyword: 'TO')				ifTrue: 					[self advance.					anEntry blockContainsMax: currentToken value.					self advance]				ifFalse: 					[anEntry blockContainsMax: anEntry blockContainsMin.					anEntry blockContainsMin: nil].			(self currentIsKeyword: 'RECORDS')				ifTrue: 					[anEntry blockContainsUnit: #records.					self advance]				ifFalse: 					[(self currentIsKeyword: 'CHARACTERS')						ifTrue: 							[anEntry blockContainsUnit: #characters.							self advance]].			^self].	"RECORD CONTAINS [int-1 TO] int-2 [CHARACTERS]"	(self currentIsKeyword: 'RECORD')		ifTrue: 			[self advance.			(self currentIsKeyword: 'CONTAINS') ifTrue: [self advance].			anEntry recordContainsMin: currentToken value.			self advance.			(self currentIsKeyword: 'TO')				ifTrue: 					[self advance.					anEntry recordContainsMax: currentToken value.					self advance]				ifFalse: 					[anEntry recordContainsMax: anEntry recordContainsMin.					anEntry recordContainsMin: nil].			(self currentIsKeyword: 'CHARACTERS') ifTrue: [self advance].			^self].	"LABEL (RECORD IS | RECORDS ARE) (STANDARD | OMITTED | data-name)"	(self currentIsKeyword: 'LABEL')		ifTrue: 			[self advance.			((self currentIsKeyword: 'RECORD') or: [self currentIsKeyword: 'RECORDS'])				ifTrue: [self advance].			((self currentIsKeyword: 'IS') or: [self currentIsKeyword: 'ARE'])				ifTrue: [self advance].			(self currentIsKeyword: 'STANDARD')				ifTrue: 					[anEntry labelRecords: #standard.					self advance]				ifFalse: 					[(self currentIsKeyword: 'OMITTED')						ifTrue: 							[anEntry labelRecords: #omitted.							self advance]						ifFalse: [anEntry labelRecords: nil]].			^self].	"VALUE OF data-name IS (literal | data-name)"	(self currentIsKeyword: 'VALUE')		ifTrue: 			[self advance.			(self currentIsKeyword: 'OF') ifTrue: [self advance].						[self currentIsName and: 					[(self currentIsKeyword: 'BLOCK') not and: 							[(self currentIsKeyword: 'RECORD') not								and: [(self currentIsKeyword: 'LABEL') not]]]]					whileTrue: 						[self advance.	"data-name"						(self currentIsKeyword: 'IS') ifTrue: [self advance].						self advance	"literal or data-name"].			^self].	"DATA (RECORD IS | RECORDS ARE) data-name..."	(self currentIsKeyword: 'DATA')		ifTrue: 			[self advance.			((self currentIsKeyword: 'RECORD') or: [self currentIsKeyword: 'RECORDS'])				ifTrue: [self advance].			((self currentIsKeyword: 'IS') or: [self currentIsKeyword: 'ARE'])				ifTrue: [self advance].						[self currentIsName and: 					[(self currentIsKeyword: 'BLOCK') not and: 							[(self currentIsKeyword: 'RECORD') not								and: [(self currentIsKeyword: 'LABEL') not and: [self isDivisionHeader not]]]]]					whileTrue: [anEntry dataRecords add: self consumeName].			^self].	"LINAGE IS (int | data-name) LINES [subclauses]"	(self currentIsKeyword: 'LINAGE')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			anEntry linageLines: currentToken value.			self advance.			(self currentIsKeyword: 'LINES') ifTrue: [self advance].			(self currentIsKeyword: 'WITH')				ifTrue: 					[self advance.					(self currentIsKeyword: 'FOOTING') ifTrue: [self advance].					(self currentIsKeyword: 'AT') ifTrue: [self advance].					anEntry linageFooting: currentToken value.					self advance].			(self currentIsKeyword: 'LINES')				ifTrue: 					[self advance.					(self currentIsKeyword: 'AT') ifTrue: [self advance].					(self currentIsKeyword: 'TOP')						ifTrue: 							[self advance.							anEntry linageTop: currentToken value.							self advance]].			(self currentIsKeyword: 'LINES')				ifTrue: 					[self advance.					(self currentIsKeyword: 'AT') ifTrue: [self advance].					(self currentIsKeyword: 'BOTTOM')						ifTrue: 							[self advance.							anEntry linageBottom: currentToken value.							self advance]].			^self].	"RECORDING MODE IS (F | V | U | S)"	(self currentIsKeyword: 'RECORDING')		ifTrue: 			[self advance.			(self currentIsKeyword: 'MODE') ifTrue: [self advance].			(self currentIsKeyword: 'IS') ifTrue: [self advance].			mode := currentToken value asUppercase.			anEntry recordingMode: mode asSymbol.			self advance.			^self].	"CODE-SET IS alphabet-name"	(self currentIsKeyword: 'CODE-SET')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			anEntry codeSet: self consumeName.			^self].	"EXTERNAL"	(self currentIsKeyword: 'EXTERNAL')		ifTrue: 			[anEntry external: true.			self advance.			^self].	"GLOBAL"	(self currentIsKeyword: 'GLOBAL')		ifTrue: 			[anEntry global: true.			self advance.			^self].	"Unknown — skip to avoid looping."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDataItems">parseDataItems	"Parse a flat sequence of data description entries and return them as an	 OrderedCollection of CobolDataItem.  Stops at any section/division header,	 at FD/SD (back to FILE SECTION level), or at EOF."	| items |	items := OrderedCollection new.	[ self isDataItem ] whileTrue: [ items add: self parseDataItem ].	^ items</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '11:03:04 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 11:03:04 AM on April 8, 2026."</do-it><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataItem">isDataItem	"True when the current token is a valid COBOL level number."	| n |	currentToken isInteger ifFalse: [ ^ false ].	n := currentToken value asInteger.	^ (n &gt;= 1 and: [ n &lt;= 49 ]) or: [		  n = 66 or: [ n = 77 or: [ n = 78 or: [ n = 88 ] ] ] ]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataItem">isDataItem	"True when the current token is a valid COBOL level number."	| n |	currentToken isInteger ifFalse: [^false].	n := currentToken value asInteger.	^(n &gt;= 1 and: [n &lt;= 49])		or: [n = 66 or: [n = 77 or: [n = 78 or: [n = 88]]]]</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDataItem">parseDataItem	"Parse one data description entry and return a CobolDataItem.	 Dispatches to the correct handler based on level number."	| level |	level := currentToken value asInteger.	self advance.	level = 66 ifTrue: [ ^ self parseRenamesEntry: level ].	level = 88 ifTrue: [ ^ self parseConditionNameEntry: level ].	^ self parseRegularDataItem: level</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDataItem">parseDataItem	"Parse one data description entry and return a CobolDataItem.	 Dispatches to the correct handler based on level number."	| level |	level := currentToken value asInteger.	self advance.	level = 66 ifTrue: [^self parseRenamesEntry: level].	level = 88 ifTrue: [^self parseConditionNameEntry: level].	^self parseRegularDataItem: level</body></methods><class><name>CobolDataItem</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseRegularDataItem:">parseRegularDataItem: aLevel	"Parse a regular data description entry (levels 01–49, 77, 78).	 Returns a CobolDataItem."	| item |	item := CobolDataItem new.	item levelNumber: aLevel.	"Optional data name or FILLER."	self isDataItemNameToken		ifTrue: [ item dataName: self consumeName ]		ifFalse: [ item dataName: nil ].	"Clauses in any order, up to the terminating period."	[	self currentIsPeriod or: [		self currentIsEof or: [			self isDataItem or: [				self isDataDivisionSectionHeader or: [					self isDivisionHeader or: [						(self currentIsKeyword: 'FD') or: [ self currentIsKeyword: 'SD' ] ] ] ] ] ] ]		whileFalse: [ self parseDataItemClause: item ].	self currentIsPeriod ifTrue: [ self advance ].	^ item</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseRegularDataItem:">parseRegularDataItem: aLevel	"Parse a regular data description entry (levels 01–49, 77, 78).	 Returns a CobolDataItem."	| item |	item := CobolDataItem new.	item levelNumber: aLevel.	"Optional data name or FILLER."	self isDataItemNameToken		ifTrue: [item dataName: self consumeName]		ifFalse: [item dataName: nil].	"Clauses in any order, up to the terminating period."		[self currentIsPeriod or: 			[self currentIsEof or: 					[self isDataItem or: 							[self isDataDivisionSectionHeader or: 									[self isDivisionHeader										or: [(self currentIsKeyword: 'FD') or: [self currentIsKeyword: 'SD']]]]]]]			whileFalse: [self parseDataItemClause: item].	self currentIsPeriod ifTrue: [self advance].	^item</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataItemNameToken">isDataItemNameToken	"True when the current token can be the data-name after a level number.	 Clause-opening keywords are excluded so they are parsed as clauses."	currentToken isIdentifier ifTrue: [ ^ true ].	currentToken isKeyword ifFalse: [ ^ false ].	^ self isDataItemClauseKeyword not</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataItemNameToken">isDataItemNameToken	"True when the current token can be the data-name after a level number.	 Clause-opening keywords are excluded so they are parsed as clauses."	currentToken isIdentifier ifTrue: [^true].	currentToken isKeyword ifFalse: [^false].	^self isDataItemClauseKeyword not</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataItemClauseKeyword">isDataItemClauseKeyword	"True when the current keyword opens a data description clause."	| kw |	currentToken isKeyword ifFalse: [ ^ false ].	kw := currentToken value asUppercase.	^ #( 'REDEFINES' 'EXTERNAL' 'GLOBAL' 'PICTURE' 'PIC' 'USAGE' 'SIGN'	     'OCCURS' 'SYNCHRONIZED' 'SYNC' 'JUSTIFIED' 'JUST' 'BLANK'	     'VALUE' 'VALUES' 'RENAMES' ) includes: kw</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isDataItemClauseKeyword">isDataItemClauseKeyword	"True when the current keyword opens a data description clause."	| kw |	currentToken isKeyword ifFalse: [^false].	kw := currentToken value asUppercase.	^#('REDEFINES' 'EXTERNAL' 'GLOBAL' 'PICTURE' 'PIC' 'USAGE' 'SIGN' 'OCCURS' 'SYNCHRONIZED' 'SYNC' 'JUSTIFIED' 'JUST' 'BLANK' 'VALUE' 'VALUES' 'RENAMES')		includes: kw</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDataItemClause:">parseDataItemClause: anItem	"Parse one clause of a data description entry and populate anItem."	"REDEFINES data-name"	(self currentIsKeyword: 'REDEFINES') ifTrue: [		self advance.		anItem redefines: self consumeName.		^ self ].	"EXTERNAL"	(self currentIsKeyword: 'EXTERNAL') ifTrue: [		anItem external: true.		self advance.		^ self ].	"GLOBAL"	(self currentIsKeyword: 'GLOBAL') ifTrue: [		anItem global: true.		self advance.		^ self ].	"PICTURE [IS] picture-string   (also PIC)"	((self currentIsKeyword: 'PICTURE') or: [		 self currentIsKeyword: 'PIC' ]) ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		anItem picture: self parsePictureString.		^ self ].	"USAGE [IS] usage-type"	(self currentIsKeyword: 'USAGE') ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		anItem usage: self parseUsageType.		^ self ].	"SIGN [IS] LEADING|TRAILING [SEPARATE [CHARACTER]]"	(self currentIsKeyword: 'SIGN') ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		(self currentIsKeyword: 'LEADING')			ifTrue: [				anItem sign: #leading.				self advance ]			ifFalse: [				(self currentIsKeyword: 'TRAILING') ifTrue: [					anItem sign: #trailing.					self advance ] ].		(self currentIsKeyword: 'SEPARATE') ifTrue: [			self advance.			(self currentIsKeyword: 'CHARACTER') ifTrue: [ self advance ].			anItem signSeparate: true ].		^ self ].	"OCCURS [int-1 TO] int-2 TIMES …"	(self currentIsKeyword: 'OCCURS') ifTrue: [		anItem occurs: self parseOccursClause.		^ self ].	"SYNCHRONIZED|SYNC [LEFT|RIGHT]"	((self currentIsKeyword: 'SYNCHRONIZED') or: [		 self currentIsKeyword: 'SYNC' ]) ifTrue: [		self advance.		(self currentIsKeyword: 'LEFT')			ifTrue: [				anItem synchronized: #left.				self advance ]			ifFalse: [				(self currentIsKeyword: 'RIGHT')					ifTrue: [						anItem synchronized: #right.						self advance ]					ifFalse: [ anItem synchronized: #both ] ].		^ self ].	"JUSTIFIED|JUST [RIGHT]"	((self currentIsKeyword: 'JUSTIFIED') or: [		 self currentIsKeyword: 'JUST' ]) ifTrue: [		self advance.		(self currentIsKeyword: 'RIGHT') ifTrue: [ self advance ].		anItem justified: true.		^ self ].	"BLANK WHEN ZERO"	(self currentIsKeyword: 'BLANK') ifTrue: [		self advance.		(self currentIsKeyword: 'WHEN') ifTrue: [ self advance ].		(self currentIsKeyword: 'ZERO') ifTrue: [ self advance ].		anItem blankWhenZero: true.		^ self ].	"VALUE [IS] literal"	(self currentIsKeyword: 'VALUE') ifTrue: [		self advance.		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		anItem value: currentToken value asString.		self advance.		^ self ].	"Unknown clause token — skip to avoid infinite loop."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseDataItemClause:">parseDataItemClause: anItem	"Parse one clause of a data description entry and populate anItem."	"REDEFINES data-name"	(self currentIsKeyword: 'REDEFINES')		ifTrue: 			[self advance.			anItem redefines: self consumeName.			^self].	"EXTERNAL"	(self currentIsKeyword: 'EXTERNAL')		ifTrue: 			[anItem external: true.			self advance.			^self].	"GLOBAL"	(self currentIsKeyword: 'GLOBAL')		ifTrue: 			[anItem global: true.			self advance.			^self].	"PICTURE [IS] picture-string   (also PIC)"	((self currentIsKeyword: 'PICTURE') or: [self currentIsKeyword: 'PIC'])		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			anItem picture: self parsePictureString.			^self].	"USAGE [IS] usage-type"	(self currentIsKeyword: 'USAGE')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			anItem usage: self parseUsageType.			^self].	"SIGN [IS] LEADING|TRAILING [SEPARATE [CHARACTER]]"	(self currentIsKeyword: 'SIGN')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			(self currentIsKeyword: 'LEADING')				ifTrue: 					[anItem sign: #leading.					self advance]				ifFalse: 					[(self currentIsKeyword: 'TRAILING')						ifTrue: 							[anItem sign: #trailing.							self advance]].			(self currentIsKeyword: 'SEPARATE')				ifTrue: 					[self advance.					(self currentIsKeyword: 'CHARACTER') ifTrue: [self advance].					anItem signSeparate: true].			^self].	"OCCURS [int-1 TO] int-2 TIMES …"	(self currentIsKeyword: 'OCCURS')		ifTrue: 			[anItem occurs: self parseOccursClause.			^self].	"SYNCHRONIZED|SYNC [LEFT|RIGHT]"	((self currentIsKeyword: 'SYNCHRONIZED')		or: [self currentIsKeyword: 'SYNC'])			ifTrue: 				[self advance.				(self currentIsKeyword: 'LEFT')					ifTrue: 						[anItem synchronized: #left.						self advance]					ifFalse: 						[(self currentIsKeyword: 'RIGHT')							ifTrue: 								[anItem synchronized: #right.								self advance]							ifFalse: [anItem synchronized: #both]].				^self].	"JUSTIFIED|JUST [RIGHT]"	((self currentIsKeyword: 'JUSTIFIED') or: [self currentIsKeyword: 'JUST'])		ifTrue: 			[self advance.			(self currentIsKeyword: 'RIGHT') ifTrue: [self advance].			anItem justified: true.			^self].	"BLANK WHEN ZERO"	(self currentIsKeyword: 'BLANK')		ifTrue: 			[self advance.			(self currentIsKeyword: 'WHEN') ifTrue: [self advance].			(self currentIsKeyword: 'ZERO') ifTrue: [self advance].			anItem blankWhenZero: true.			^self].	"VALUE [IS] literal"	(self currentIsKeyword: 'VALUE')		ifTrue: 			[self advance.			(self currentIsKeyword: 'IS') ifTrue: [self advance].			anItem value: currentToken value asString.			self advance.			^self].	"Unknown clause token — skip to avoid infinite loop."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parsePictureString">parsePictureString	"Collect picture character tokens and return the concatenated picture string.	 Stops at a period, EOF, or any clause-starting keyword."	| s |	s := WriteStream on: String new.	[	self currentIsPeriod or: [		self currentIsEof or: [ self isPictureTerminatingKeyword ] ] ]		whileFalse: [			| v |			v := currentToken value.			v notNil ifTrue: [ s nextPutAll: v asString ].			self advance ].	^ s contents</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parsePictureString">parsePictureString	"Collect picture character tokens and return the concatenated picture string.	 Stops at a period, EOF, or any clause-starting keyword."	| s |	s := WriteStream on: String new.		[self currentIsPeriod		or: [self currentIsEof or: [self isPictureTerminatingKeyword]]]			whileFalse: 				[| v |				v := currentToken value.				v notNil ifTrue: [s nextPutAll: v asString].				self advance].	^s contents</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isPictureTerminatingKeyword">isPictureTerminatingKeyword	"True when the current keyword cannot be part of a picture character string."	| kw |	currentToken isKeyword ifFalse: [ ^ false ].	kw := currentToken value asUppercase.	^ #( 'USAGE' 'SIGN' 'OCCURS' 'SYNCHRONIZED' 'SYNC' 'JUSTIFIED'	     'JUST' 'BLANK' 'VALUE' 'VALUES' 'REDEFINES' 'GLOBAL' 'EXTERNAL'	     'PICTURE' 'PIC' 'INDEXED' ) includes: kw</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="isPictureTerminatingKeyword">isPictureTerminatingKeyword	"True when the current keyword cannot be part of a picture character string."	| kw |	currentToken isKeyword ifFalse: [^false].	kw := currentToken value asUppercase.	^#('USAGE' 'SIGN' 'OCCURS' 'SYNCHRONIZED' 'SYNC' 'JUSTIFIED' 'JUST' 'BLANK' 'VALUE' 'VALUES' 'REDEFINES' 'GLOBAL' 'EXTERNAL' 'PICTURE' 'PIC' 'INDEXED')		includes: kw</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseUsageType">parseUsageType	"Consume and return the USAGE type as a Symbol."	| kw sym |	kw := currentToken value asUppercase.	sym := kw asSymbol.	self advance.	^ sym</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseUsageType">parseUsageType	"Consume and return the USAGE type as a Symbol."	| kw sym |	kw := currentToken value asUppercase.	sym := kw asSymbol.	self advance.	^sym</body></methods><class><name>CobolOccursClause</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseOccursClause">parseOccursClause	"Parse: OCCURS [int-1 TO] int-2 TIMES	          [DEPENDING ON data-name]	          [{ASCENDING|DESCENDING} KEY [IS] data-name …] …	          [INDEXED BY index-name …]	 Returns a CobolOccursClause."	| clause first |	clause := CobolOccursClause new.	self consumeKeyword: 'OCCURS'.	first := currentToken value.	self advance.	(self currentIsKeyword: 'TO')		ifTrue: [			self advance.			clause minTimes: first.			clause maxTimes: currentToken value.			self advance ]		ifFalse: [ clause maxTimes: first ].	(self currentIsKeyword: 'TIMES') ifTrue: [ self advance ].	(self currentIsKeyword: 'DEPENDING') ifTrue: [		self advance.		(self currentIsKeyword: 'ON') ifTrue: [ self advance ].		clause dependingOn: self consumeName ].	[	(self currentIsKeyword: 'ASCENDING') or: [		self currentIsKeyword: 'DESCENDING' ] ] whileTrue: [		| dir |		dir := currentToken value asUppercase.		self advance.		(self currentIsKeyword: 'KEY') ifTrue: [ self advance ].		(self currentIsKeyword: 'IS') ifTrue: [ self advance ].		[		self currentIsName and: [			(self currentIsKeyword: 'ASCENDING') not and: [				(self currentIsKeyword: 'DESCENDING') not and: [					(self currentIsKeyword: 'INDEXED') not ] ] ] ] whileTrue: [			| key |			key := self consumeName.			dir = 'ASCENDING'				ifTrue: [ clause ascendingKeys add: key ]				ifFalse: [ clause descendingKeys add: key ] ] ].	(self currentIsKeyword: 'INDEXED') ifTrue: [		self advance.		(self currentIsKeyword: 'BY') ifTrue: [ self advance ].		[		self currentIsName and: [			(self currentIsKeyword: 'ASCENDING') not and: [				(self currentIsKeyword: 'DESCENDING') not and: [					self isPictureTerminatingKeyword not ] ] ] ] whileTrue: [			clause indexedBy add: self consumeName ] ].	^ clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseOccursClause">parseOccursClause	"Parse: OCCURS [int-1 TO] int-2 TIMES	          [DEPENDING ON data-name]	          [{ASCENDING|DESCENDING} KEY [IS] data-name …] …	          [INDEXED BY index-name …]	 Returns a CobolOccursClause."	| clause first |	clause := CobolOccursClause new.	self consumeKeyword: 'OCCURS'.	first := currentToken value.	self advance.	(self currentIsKeyword: 'TO')		ifTrue: 			[self advance.			clause minTimes: first.			clause maxTimes: currentToken value.			self advance]		ifFalse: [clause maxTimes: first].	(self currentIsKeyword: 'TIMES') ifTrue: [self advance].	(self currentIsKeyword: 'DEPENDING')		ifTrue: 			[self advance.			(self currentIsKeyword: 'ON') ifTrue: [self advance].			clause dependingOn: self consumeName].		[(self currentIsKeyword: 'ASCENDING')		or: [self currentIsKeyword: 'DESCENDING']]			whileTrue: 				[| dir |				dir := currentToken value asUppercase.				self advance.				(self currentIsKeyword: 'KEY') ifTrue: [self advance].				(self currentIsKeyword: 'IS') ifTrue: [self advance].								[self currentIsName and: 						[(self currentIsKeyword: 'ASCENDING') not and: 								[(self currentIsKeyword: 'DESCENDING') not									and: [(self currentIsKeyword: 'INDEXED') not]]]]						whileTrue: 							[| key |							key := self consumeName.							dir = 'ASCENDING'								ifTrue: [clause ascendingKeys add: key]								ifFalse: [clause descendingKeys add: key]]].	(self currentIsKeyword: 'INDEXED')		ifTrue: 			[self advance.			(self currentIsKeyword: 'BY') ifTrue: [self advance].						[self currentIsName and: 					[(self currentIsKeyword: 'ASCENDING') not and: 							[(self currentIsKeyword: 'DESCENDING') not								and: [self isPictureTerminatingKeyword not]]]]					whileTrue: [clause indexedBy add: self consumeName]].	^clause</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseConditionNameEntry:">parseConditionNameEntry: aLevel	"Parse: 88 condition-name VALUE[S] [IS|ARE] literal [{THROUGH|THRU} literal] …	 Returns a CobolDataItem with conditionValues set."	| item ranges from to |	item := CobolDataItem new.	item levelNumber: aLevel.	item dataName: self consumeName.	item conditionValues: (ranges := OrderedCollection new).	((self currentIsKeyword: 'VALUE') or: [		 self currentIsKeyword: 'VALUES' ]) ifTrue: [ self advance ].	((self currentIsKeyword: 'IS') or: [ self currentIsKeyword: 'ARE' ])		ifTrue: [ self advance ].	[	self currentIsEof or: [ self currentIsPeriod or: [ self isDataItem ] ] ]		whileFalse: [			from := currentToken value asString.			self advance.			((self currentIsKeyword: 'THROUGH') or: [				 self currentIsKeyword: 'THRU' ])				ifTrue: [					self advance.					to := currentToken value asString.					self advance ]				ifFalse: [ to := from ].			ranges add: from -&gt; to.			(self currentIsKeyword: 'ALSO') ifTrue: [ self advance ] ].	self currentIsPeriod ifTrue: [ self advance ].	^ item</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseConditionNameEntry:">parseConditionNameEntry: aLevel	"Parse: 88 condition-name VALUE[S] [IS|ARE] literal [{THROUGH|THRU} literal] …	 Returns a CobolDataItem with conditionValues set."	| item ranges from to |	item := CobolDataItem new.	item levelNumber: aLevel.	item dataName: self consumeName.	item conditionValues: (ranges := OrderedCollection new).	((self currentIsKeyword: 'VALUE') or: [self currentIsKeyword: 'VALUES'])		ifTrue: [self advance].	((self currentIsKeyword: 'IS') or: [self currentIsKeyword: 'ARE'])		ifTrue: [self advance].	[self currentIsEof or: [self currentIsPeriod or: [self isDataItem]]]		whileFalse: 			[from := currentToken value asString.			self advance.			((self currentIsKeyword: 'THROUGH') or: [self currentIsKeyword: 'THRU'])				ifTrue: 					[self advance.					to := currentToken value asString.					self advance]				ifFalse: [to := from].			ranges add: from -&gt; to.			(self currentIsKeyword: 'ALSO') ifTrue: [self advance]].	self currentIsPeriod ifTrue: [self advance].	^item</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseRenamesEntry:">parseRenamesEntry: aLevel	"Parse: 66 data-name RENAMES data-name-1 [{THROUGH|THRU} data-name-2] .	 Returns a CobolDataItem with renamesFrom / renamesThru set."	| item |	item := CobolDataItem new.	item levelNumber: aLevel.	item dataName: self consumeName.	self consumeKeyword: 'RENAMES'.	item renamesFrom: self consumeName.	((self currentIsKeyword: 'THROUGH') or: [		 self currentIsKeyword: 'THRU' ]) ifTrue: [		self advance.		item renamesThru: self consumeName ].	self currentIsPeriod ifTrue: [ self advance ].	^ item</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseRenamesEntry:">parseRenamesEntry: aLevel	"Parse: 66 data-name RENAMES data-name-1 [{THROUGH|THRU} data-name-2] .	 Returns a CobolDataItem with renamesFrom / renamesThru set."	| item |	item := CobolDataItem new.	item levelNumber: aLevel.	item dataName: self consumeName.	self consumeKeyword: 'RENAMES'.	item renamesFrom: self consumeName.	((self currentIsKeyword: 'THROUGH') or: [self currentIsKeyword: 'THRU'])		ifTrue: 			[self advance.			item renamesThru: self consumeName].	self currentIsPeriod ifTrue: [self advance].	^item</body></methods><class><name>CobolWorkingStorageSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseWorkingStorageSection">parseWorkingStorageSection	"Parse: WORKING-STORAGE SECTION . data-item*	 Returns a CobolWorkingStorageSection."	| section |	section := CobolWorkingStorageSection new.	self consumeKeyword: 'WORKING-STORAGE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseWorkingStorageSection">parseWorkingStorageSection	"Parse: WORKING-STORAGE SECTION . data-item*	 Returns a CobolWorkingStorageSection."	| section |	section := CobolWorkingStorageSection new.	self consumeKeyword: 'WORKING-STORAGE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^section</body></methods><class><name>CobolLocalStorageSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseLocalStorageSection">parseLocalStorageSection	"Parse: LOCAL-STORAGE SECTION . data-item*	 Returns a CobolLocalStorageSection."	| section |	section := CobolLocalStorageSection new.	self consumeKeyword: 'LOCAL-STORAGE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseLocalStorageSection">parseLocalStorageSection	"Parse: LOCAL-STORAGE SECTION . data-item*	 Returns a CobolLocalStorageSection."	| section |	section := CobolLocalStorageSection new.	self consumeKeyword: 'LOCAL-STORAGE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^section</body></methods><class><name>CobolLinkageSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseLinkageSection">parseLinkageSection	"Parse: LINKAGE SECTION . data-item*	 Returns a CobolLinkageSection."	| section |	section := CobolLinkageSection new.	self consumeKeyword: 'LINKAGE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseLinkageSection">parseLinkageSection	"Parse: LINKAGE SECTION . data-item*	 Returns a CobolLinkageSection."	| section |	section := CobolLinkageSection new.	self consumeKeyword: 'LINKAGE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^section</body></methods><class><name>CobolScreenSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseScreenSection">parseScreenSection	"Parse: SCREEN SECTION . screen-description*	 Screen description entries share the CobolDataItem structure with	 additional display-layout clauses mapped to the value slot.	 Returns a CobolScreenSection."	| section |	section := CobolScreenSection new.	self consumeKeyword: 'SCREEN'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseScreenSection">parseScreenSection	"Parse: SCREEN SECTION . screen-description*	 Screen description entries share the CobolDataItem structure with	 additional display-layout clauses mapped to the value slot.	 Returns a CobolScreenSection."	| section |	section := CobolScreenSection new.	self consumeKeyword: 'SCREEN'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^section</body></methods><class><name>CobolCommunicationSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseCommunicationSection">parseCommunicationSection	"Parse: COMMUNICATION SECTION . { CD entry } *	 Returns a CobolCommunicationSection."	| section |	section := CobolCommunicationSection new.	self consumeKeyword: 'COMMUNICATION'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	[ self currentIsKeyword: 'CD' ] whileTrue: [		section entries add: self parseCommunicationDescriptionEntry ].	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseCommunicationSection">parseCommunicationSection	"Parse: COMMUNICATION SECTION . { CD entry } *	 Returns a CobolCommunicationSection."	| section |	section := CobolCommunicationSection new.	self consumeKeyword: 'COMMUNICATION'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	[self currentIsKeyword: 'CD']		whileTrue: [section entries add: self parseCommunicationDescriptionEntry].	^section</body></methods><class><name>CobolCommunicationDescriptionEntry</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseCommunicationDescriptionEntry">parseCommunicationDescriptionEntry	"Parse one CD entry.	 Returns a CobolCommunicationDescriptionEntry.	 Grammar:	   CD cd-name [FOR [INITIAL] (INPUT|OUTPUT|I-O)]	     clause* .	   record-description*	"	| entry |	entry := CobolCommunicationDescriptionEntry new.	self consumeKeyword: 'CD'.	entry cdName: self consumeName.	(self currentIsKeyword: 'FOR') ifTrue: [		self advance.		(self currentIsKeyword: 'INITIAL') ifTrue: [ self advance ].		(self currentIsKeyword: 'INPUT')			ifTrue: [				entry direction: #input.				self advance ]			ifFalse: [				(self currentIsKeyword: 'OUTPUT')					ifTrue: [						entry direction: #output.						self advance ]					ifFalse: [						(self currentIsKeyword: 'I-O') ifTrue: [							entry direction: #io.							self advance ] ] ] ].	"Collect remaining clauses as keyword → data-name pairs until period."	[	self currentIsPeriod or: [		self currentIsEof or: [			self isDataDivisionSectionHeader or: [ self isDivisionHeader ] ] ] ]		whileFalse: [			| key |			key := currentToken value asString.			self advance.			(self currentIsKeyword: 'IS') ifTrue: [ self advance ].			self currentIsName				ifTrue: [ entry clauses at: key put: self consumeName ]				ifFalse: [ entry clauses at: key put: nil ] ].	self currentIsPeriod ifTrue: [ self advance ].	entry items: self parseDataItems.	^ entry</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseCommunicationDescriptionEntry">parseCommunicationDescriptionEntry	"Parse one CD entry.	 Returns a CobolCommunicationDescriptionEntry.	 Grammar:	   CD cd-name [FOR [INITIAL] (INPUT|OUTPUT|I-O)]	     clause* .	   record-description*	"	| entry |	entry := CobolCommunicationDescriptionEntry new.	self consumeKeyword: 'CD'.	entry cdName: self consumeName.	(self currentIsKeyword: 'FOR')		ifTrue: 			[self advance.			(self currentIsKeyword: 'INITIAL') ifTrue: [self advance].			(self currentIsKeyword: 'INPUT')				ifTrue: 					[entry direction: #input.					self advance]				ifFalse: 					[(self currentIsKeyword: 'OUTPUT')						ifTrue: 							[entry direction: #output.							self advance]						ifFalse: 							[(self currentIsKeyword: 'I-O')								ifTrue: 									[entry direction: #io.									self advance]]]].	"Collect remaining clauses as keyword → data-name pairs until period."		[self currentIsPeriod or: 			[self currentIsEof				or: [self isDataDivisionSectionHeader or: [self isDivisionHeader]]]]			whileFalse: 				[| key |				key := currentToken value asString.				self advance.				(self currentIsKeyword: 'IS') ifTrue: [self advance].				self currentIsName					ifTrue: [entry clauses at: key put: self consumeName]					ifFalse: [entry clauses at: key put: nil]].	self currentIsPeriod ifTrue: [self advance].	entry items: self parseDataItems.	^entry</body></methods><class><name>CobolReportSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><class><name>CobolReportSection</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseReportSection">parseReportSection	"Parse: REPORT SECTION . { RD entry } *	 Returns a CobolReportSection."	| section |	section := CobolReportSection new.	self consumeKeyword: 'REPORT'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	[ self currentIsKeyword: 'RD' ] whileTrue: [		section entries add: self parseReportDescriptionEntry ].	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseReportSection">parseReportSection	"Parse: REPORT SECTION . { RD entry } *	 Returns a CobolReportSection."	| section |	section := CobolReportSection new.	self consumeKeyword: 'REPORT'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	[self currentIsKeyword: 'RD']		whileTrue: [section entries add: self parseReportDescriptionEntry].	^section</body></methods><class><name>CobolReportDescriptionEntry</name><environment>Smalltalk</environment><super>CobolAst</super><private>false</private><indexed-type>none</indexed-type><inst-vars></inst-vars><class-inst-vars></class-inst-vars><imports></imports><category></category><attributes><package>CobolStudio</package></attributes></class><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseReportDescriptionEntry">parseReportDescriptionEntry	"Parse one RD entry and its report group descriptions.	 Returns a CobolReportDescriptionEntry.	 Grammar:	   RD report-name	     [GLOBAL]	     [CODE literal]	     [CONTROL IS|CONTROLS ARE {FINAL|data-name}…]	     [PAGE [LIMIT IS|LIMITS ARE] integer LINE[S]	       [HEADING integer]	       [FIRST DETAIL integer]	       [LAST DETAIL integer]	       [FOOTING integer]]	   .	   report-group-description*	"	| entry |	entry := CobolReportDescriptionEntry new.	self consumeKeyword: 'RD'.	entry reportName: self consumeName.	[	self currentIsPeriod or: [		self currentIsEof or: [			self isDataDivisionSectionHeader or: [ self isDivisionHeader ] ] ] ]		whileFalse: [ self parseReportDescriptionClause: entry ].	self currentIsPeriod ifTrue: [ self advance ].	entry items: self parseDataItems.	^ entry</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseReportDescriptionEntry">parseReportDescriptionEntry	"Parse one RD entry and its report group descriptions.	 Returns a CobolReportDescriptionEntry.	 Grammar:	   RD report-name	     [GLOBAL]	     [CODE literal]	     [CONTROL IS|CONTROLS ARE {FINAL|data-name}…]	     [PAGE [LIMIT IS|LIMITS ARE] integer LINE[S]	       [HEADING integer]	       [FIRST DETAIL integer]	       [LAST DETAIL integer]	       [FOOTING integer]]	   .	   report-group-description*	"	| entry |	entry := CobolReportDescriptionEntry new.	self consumeKeyword: 'RD'.	entry reportName: self consumeName.		[self currentIsPeriod or: 			[self currentIsEof				or: [self isDataDivisionSectionHeader or: [self isDivisionHeader]]]]			whileFalse: [self parseReportDescriptionClause: entry].	self currentIsPeriod ifTrue: [self advance].	entry items: self parseDataItems.	^entry</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseReportDescriptionClause:">parseReportDescriptionClause: anEntry	"Parse one optional clause of an RD entry."	"GLOBAL"	(self currentIsKeyword: 'GLOBAL') ifTrue: [		anEntry global: true.		self advance.		^ self ].	"CODE literal"	(self currentIsKeyword: 'CODE') ifTrue: [		self advance.		self advance.		^ self ].	"CONTROL IS | CONTROLS ARE {FINAL|data-name}…"	((self currentIsKeyword: 'CONTROL') or: [		 self currentIsKeyword: 'CONTROLS' ]) ifTrue: [		self advance.		((self currentIsKeyword: 'IS') or: [ self currentIsKeyword: 'ARE' ])			ifTrue: [ self advance ].		[		self currentIsName and: [			(self currentIsKeyword: 'PAGE') not and: [				self isDivisionHeader not ] ] ] whileTrue: [			anEntry controls add: self consumeName ].		^ self ].	"PAGE [LIMIT IS | LIMITS ARE] integer LINE[S] [subclauses]"	(self currentIsKeyword: 'PAGE') ifTrue: [		self advance.		((self currentIsKeyword: 'LIMIT') or: [			 self currentIsKeyword: 'LIMITS' ]) ifTrue: [ self advance ].		((self currentIsKeyword: 'IS') or: [ self currentIsKeyword: 'ARE' ])			ifTrue: [ self advance ].		anEntry pageLines: currentToken value.		self advance.		((self currentIsKeyword: 'LINE') or: [			 self currentIsKeyword: 'LINES' ]) ifTrue: [ self advance ].		(self currentIsKeyword: 'HEADING') ifTrue: [			self advance.			anEntry headingLine: currentToken value.			self advance ].		(self currentIsKeyword: 'FIRST') ifTrue: [			self advance.			(self currentIsKeyword: 'DETAIL') ifTrue: [ self advance ].			anEntry firstDetailLine: currentToken value.			self advance ].		(self currentIsKeyword: 'LAST') ifTrue: [			self advance.			(self currentIsKeyword: 'DETAIL') ifTrue: [ self advance ].			anEntry lastDetailLine: currentToken value.			self advance ].		(self currentIsKeyword: 'FOOTING') ifTrue: [			self advance.			anEntry footingLine: currentToken value.			self advance ].		^ self ].	"Unknown — skip."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseReportDescriptionClause:">parseReportDescriptionClause: anEntry	"Parse one optional clause of an RD entry."	"GLOBAL"	(self currentIsKeyword: 'GLOBAL')		ifTrue: 			[anEntry global: true.			self advance.			^self].	"CODE literal"	(self currentIsKeyword: 'CODE')		ifTrue: 			[self advance.			self advance.			^self].	"CONTROL IS | CONTROLS ARE {FINAL|data-name}…"	((self currentIsKeyword: 'CONTROL')		or: [self currentIsKeyword: 'CONTROLS'])			ifTrue: 				[self advance.				((self currentIsKeyword: 'IS') or: [self currentIsKeyword: 'ARE'])					ifTrue: [self advance].								[self currentIsName					and: [(self currentIsKeyword: 'PAGE') not and: [self isDivisionHeader not]]]						whileTrue: [anEntry controls add: self consumeName].				^self].	"PAGE [LIMIT IS | LIMITS ARE] integer LINE[S] [subclauses]"	(self currentIsKeyword: 'PAGE')		ifTrue: 			[self advance.			((self currentIsKeyword: 'LIMIT') or: [self currentIsKeyword: 'LIMITS'])				ifTrue: [self advance].			((self currentIsKeyword: 'IS') or: [self currentIsKeyword: 'ARE'])				ifTrue: [self advance].			anEntry pageLines: currentToken value.			self advance.			((self currentIsKeyword: 'LINE') or: [self currentIsKeyword: 'LINES'])				ifTrue: [self advance].			(self currentIsKeyword: 'HEADING')				ifTrue: 					[self advance.					anEntry headingLine: currentToken value.					self advance].			(self currentIsKeyword: 'FIRST')				ifTrue: 					[self advance.					(self currentIsKeyword: 'DETAIL') ifTrue: [self advance].					anEntry firstDetailLine: currentToken value.					self advance].			(self currentIsKeyword: 'LAST')				ifTrue: 					[self advance.					(self currentIsKeyword: 'DETAIL') ifTrue: [self advance].					anEntry lastDetailLine: currentToken value.					self advance].			(self currentIsKeyword: 'FOOTING')				ifTrue: 					[self advance.					anEntry footingLine: currentToken value.					self advance].			^self].	"Unknown — skip."	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileSection">parseFileSection	"Parse: FILE SECTION . data-item*	 Returns a CobolLinkageSection."	| section |	section := CobolLinkageSection new.	self consumeKeyword: 'FILE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^ section</body></methods><methods><class-id>CobolParser</class-id> <category>parsing</category><body package="CobolStudio" selector="parseFileSection">parseFileSection	"Parse: FILE SECTION . data-item*	 Returns a CobolLinkageSection."	| section |	section := CobolLinkageSection new.	self consumeKeyword: 'FILE'.	self consumeKeyword: 'SECTION'.	self consumePeriod.	section items: self parseDataItems.	^section</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsEof">currentIsEof	^ currentToken isEof</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsEof">currentIsEof	^currentToken isEof</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsPeriod">currentIsPeriod	^ currentToken isPeriod</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsPeriod">currentIsPeriod	^currentToken isPeriod</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsIdentifier">currentIsIdentifier	^ currentToken isIdentifier</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsIdentifier">currentIsIdentifier	^currentToken isIdentifier</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsKeyword">currentIsKeyword	^ currentToken isKeyword</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsKeyword:">currentIsKeyword: anUppercaseString	"True when the current token is the keyword anUppercaseString."	^ currentToken isKeyword and: [		  currentToken value asUppercase = anUppercaseString ]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsKeyword:">currentIsKeyword: anUppercaseString	"True when the current token is the keyword anUppercaseString."	^currentToken isKeyword		and: [currentToken value asUppercase = anUppercaseString]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsName">currentIsName	^ currentToken isString or: [		  currentToken isIdentifier or: [ currentToken isKeyword ] ]</body></methods><methods><class-id>CobolParser</class-id> <category>testign</category><body package="CobolStudio" selector="currentIsName">currentIsName	^currentToken isString		or: [currentToken isIdentifier or: [currentToken isKeyword]]</body></methods><do-it>CobolParser organization addCategory: #consuming</do-it><methods><class-id>CobolParser</class-id> <category>consuming</category><body package="CobolStudio" selector="consumeKeyword:">consumeKeyword: anUppercaseString	"Consume the current token, asserting it is keyword anUppercaseString."	(self currentIsKeyword: anUppercaseString) ifFalse: [		self error: 'Expected ' , anUppercaseString , ' but found: '			, currentToken printString ].	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>consuming</category><body package="CobolStudio" selector="consumeKeyword:">consumeKeyword: anUppercaseString	"Consume the current token, asserting it is keyword anUppercaseString."	(self currentIsKeyword: anUppercaseString)		ifFalse: 			[self error: 'Expected ' , anUppercaseString , ' but found: '						, currentToken printString].	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>consuming</category><body package="CobolStudio" selector="consumePeriod">consumePeriod	"Consume the current token, asserting it is a period."	self currentIsPeriod ifFalse: [		self error:			'Expected period (.) but found: ' , currentToken printString ].	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>consuming</category><body package="CobolStudio" selector="consumePeriod">consumePeriod	"Consume the current token, asserting it is a period."	self currentIsPeriod		ifFalse: 			[self error: 'Expected period (.) but found: ' , currentToken printString].	self advance</body></methods><methods><class-id>CobolParser</class-id> <category>consuming</category><body package="CobolStudio" selector="consumeName">consumeName	"Consume and return the value of the current token as a COBOL name.	 Both plain identifiers and keywords are accepted (keywords can be used	 as program names in practice)."	| val |	self currentIsName ifFalse: [		self error: 'Expected a name but found: ' , currentToken printString ].	val := currentToken value.	self advance.	^ val</body></methods><methods><class-id>CobolParser</class-id> <category>consuming</category><body package="CobolStudio" selector="consumeName">consumeName	"Consume and return the value of the current token as a COBOL name.	 Both plain identifiers and keywords are accepted (keywords can be used	 as program names in practice)."	| val |	self currentIsName		ifFalse: 			[self error: 'Expected a name but found: ' , currentToken printString].	val := currentToken value.	self advance.	^val</body></methods><methods><class-id>CobolParser</class-id> <category>consuming</category><body package="CobolStudio" selector="maybeConsumePeriod">maybeConsumePeriod	self currentIsPeriod ifTrue: [self advance]</body></methods><methods><class-id>CobolParser class</class-id> <category>instance creation</category><body package="CobolStudio" selector="on:">on: aScanner	"Create a parser that reads tokens from aScanner (a CobolScanner)."	^ self new on: aScanner</body></methods><methods><class-id>CobolParser class</class-id> <category>instance creation</category><body package="CobolStudio" selector="on:">on: aScanner	"Create a parser that reads tokens from aScanner (a CobolScanner)."	^self new on: aScanner</body></methods><methods><class-id>CobolParser class</class-id> <category>instance creation</category><body package="CobolStudio" selector="onString:">onString: aString	"Create a parser from a raw COBOL source string."	^ self on: (CobolScanner on: aString)</body></methods><methods><class-id>CobolParser class</class-id> <category>instance creation</category><body package="CobolStudio" selector="onString:">onString: aString	"Create a parser from a raw COBOL source string."	^self on: (CobolScanner on: aString)</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 8, 2026' '11:31:25 AM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was creat