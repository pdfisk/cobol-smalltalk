m atEnd		ifTrue: [			currentCharacter := nil.]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1].		].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>private</category><body package="CobolStudio" selector="step">step	istream atEnd		ifTrue: [currentCharacter := nil]		ifFalse: 			[currentCharacter := istream next.			self isEndOfLine				ifTrue: 					[self column: 0.					self row: self row + 1]				ifFalse: [self column: self column + 1]].	^currentCharacter</body></methods><methods><class-id>CobolScanner</class-id> <category>character classification</category><body package="CobolStudio" selector="isIdentifierCharacter:">isIdentifierCharacter: aCharactercurrentCharacter ifNil: [^false].	^(self isAlphaNumeric: aCharacter) or: [self isMinus: aCharacter]</body></methods><methods><class-id>CobolScanner</class-id> <category>character classification</category><body package="CobolStudio" selector="isIdentifierCharacter:">isIdentifierCharacter: aCharacter	currentCharacter ifNil: [^false].	^(self isAlphaNumeric: aCharacter) or: [self isMinus: aCharacter]</body></methods><do-it>'----SNAPSHOT----'</do-it><do-it>"#('C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im' 'April 7, 2026' '12:06:21 PM')""An image file C:\ProgramData\Cincom\ObjectStudio9.3.1\ObjectStudio_PUL.im was created at 12:06:21 PM on April 7, 2026."</do-it><do-it>CobolWorkbench hello</do-it><methods><class-id>CobolWorkbench class</class-id> <category>examples</category><body package="CobolStudio" selector="hello">hello	"CobolWorkbench hello"	| scanner |	scanner := CobolScanner on: 'hello'.	^ scanner nextToken</body></methods><methods><class-id>CobolWorkbench class</class-id> <category>examples</category><body package="CobolStudio" selector="hello">hello	"CobolWorkbench hello"	| sc